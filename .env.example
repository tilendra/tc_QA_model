# Example environment variables file - DO NOT COMMIT YOUR REAL KEYS
# Copy this file to .env and replace placeholder values with your real secrets.
# Make sure to add .env to .gitignore so it is not committed.

# OpenAI API key (replace with your key)
OPENAI_API_KEY="your-openai-api-key-here"

# Optional: provider-specific keys
# MISTRAL_API_KEY="your-mistral-key-here"
# LLAMA_API_KEY="your-llama-key-here"

# Optional runtime flags
# TC_QA_MODEL_SAVE_PATH="/path/to/save/results.json"
