        if v > 110:
            return "Tachycardia — consider fever, pain, dehydration, arrhythmia."
        return "Rate within expected resting range."
    if fid == "RESP_resp_rate_Bpm_mean":
        if v < 10:
            return "Low respiratory rate — evaluate ventilatory status."
        if v > 24:
            return "Tachypnea — consider respiratory distress or metabolic cause."
        return "Respiratory rate within expected resting range."
    if fid in ("ECG_qt_interval_ms_mean", "ECG_qtc_interval_ms_mean"):
        if status == "Abnormal":
            return "Prolonged QT/QTc — consider drugs, electrolytes, clinical context."
        return "QT interval within referenced range."
    if fid == "ECG_QRS_duration_mean":
        if v >= 120:
            return "Wide QRS — consider conduction delay or bundle branch block."
        return "QRS duration within expected range."
    if fid in ("HRV_HRV_SDNN", "HRV_HRV_RMSSD", "HRV_HRV_pNN50"):
        if status == "Abnormal":
            return "Low HRV — may indicate reduced autonomic variability."
        return "HRV metric in expected range for short-term recording."
    if fid in ("PPG_SI_mean", "PPG_RI_mean", "PPG_Augmentation_index_mean", "PPG_pat_ms_mean"):
        return "Peripheral waveform index — interpret trend-wise and with device-specific norms."
    return "Interpret with clinical context."

def build_feature_rows(row):
    rows = []
    for fid, (label, unit) in FEATURE_MAP.items():
        raw = row.get(fid, None)
        if pd.isna(raw):
            raw = None
        status, note = evaluate_value(fid, raw)
        implication = build_implication(fid, raw, status)
        rows.append({
            "feature_id": fid,
            "label": label,
            "unit": unit,
            "value": raw,
            "status": status,
            "note": note,
            "implication": implication,
            "category": get_category_for_feature(fid),
        })
    return rows

def category_summary(rows):
    by_cat = {}
    for r in rows:
        by_cat.setdefault(r["category"], []).append(r)
    summaries = {}
    for cat, items in by_cat.items():
        total = len(items)
        abnormal = sum(1 for it in items if it["status"] == "Abnormal")
        borderline = sum(1 for it in items if it["status"] == "Borderline")
        missing = sum(1 for it in items if it["status"] == "Missing")
        score = (abnormal + 0.5 * borderline) / total if total > 0 else 0
        if score == 0:
            grade = "A"
        elif score <= 0.2:
            grade = "B"
        elif score <= 0.4:
            grade = "C"
        elif score <= 0.7:
            grade = "D"
        else:
            grade = "E"
        summaries[cat] = {
            "total": total, "abnormal": abnormal, "borderline": borderline,
            "missing": missing, "score": round(score, 3), "grade": grade
        }
    return summaries

def build_report_text(rows, cat_summary):
    lines = []
    lines.append("Clinical physiomarkers detailed report\n")
    lines.append("Note: reference ranges are approximate. This is a single aggregated row; correlate with clinical context and raw waveforms.\n")
    lines.append("Findings:")
    for r in rows:
        val_str = "N/A" if r["value"] is None else f"{r['value']}"
        unit = f" {r['unit']}" if r['unit'] else ""
        lines.append(f"- {r['label']} ({r['feature_id']}): {val_str}{unit} — {r['status']}. {r['implication']} ({r['note']})")
    lines.append("\nReport card (by category):")
    for cat, s in cat_summary.items():
        lines.append(f"- {cat}: Grade {s['grade']} (abnormal {s['abnormal']}/{s['total']}, borderline {s['borderline']}, score {s['score']})")
    lines.append("\nConcise interpretation (auto):")
    abn = [r for r in rows if r["status"] == "Abnormal"]
    bdr = [r for r in rows if r["status"] == "Borderline"]
    if abn:
        lines.append("- Key abnormal findings:")
        for t in abn[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    else:
        lines.append("- No strongly abnormal values detected in the mapped features.")
    if bdr:
        lines.append("- Borderline observations to watch:")
        for t in bdr[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    lines.append("\nSuggested next steps (non-urgent):")
    lines.append("1) Verify abnormal values against raw data and clinical context (ECG strips, waveform, cuff BP).")
    lines.append("2) Review medications and electrolytes if QT/QTc prolonged or HRV very low.")
    lines.append("3) Repeat measurement or monitor if hemodynamic instability suspected (MAP, Shock Index).")
    lines.append("\nUncertainty & limitations: single aggregated row; device-specific indices need population norms. Not a diagnosis.")
    return "\n".join(lines)

def create_prompt_for_llm(report_text):
    guidance = (
        "You are a clinical-style assistant. Using the structured report below, produce a concise interpretation "
        "in 4-6 short bullets — each: finding, implication, and degree of certainty (low/medium/high). "
        "Do NOT provide definitive diagnoses. Conclude with 2 recommended non-urgent next steps."
    )
    return f"Structured physiomarkers report:\n\n{report_text}\n\n{guidance}"

# Updated wrappers: accept api_key and model as parameters (do not rely only on env)
def call_openai(prompt, api_key=None, model=None, max_tokens=300, temperature=0.2):
    model = model or DEFAULT_OPENAI_MODEL
    api_key = api_key or os.getenv("OPENAI_API_KEY")
    if not api_key or openai is None:
        return None

    # Try new OpenAI client (openai>=1.0.0): openai.OpenAI(...)
    try:
        if hasattr(openai, "OpenAI"):
            # New library interface
            client = openai.OpenAI(api_key=api_key)
            resp = client.chat.completions.create(
                model=model,
                messages=[
                    {"role": "system", "content": "You are a concise clinical summarizer."},
                    {"role": "user", "content": prompt}
                ],
                max_tokens=max_tokens,
                temperature=temperature,
            )
            # Extract message content robustly
            content = None
            try:
                # preferred attribute access when SDK returns objects
                content = resp.choices[0].message.content
            except Exception:
                try:
                    # dict-like access
                    content = resp["choices"][0]["message"]["content"]
                except Exception:
                    content = str(resp)
            return {"provider": "openai", "model": model, "text": content}
        else:
            # Older openai package interface fallback
            openai.api_key = api_key
            resp = openai.ChatCompletion.create(
                model=model,
                messages=[
                    {"role": "system", "content": "You are a concise clinical summarizer."},
                    {"role": "user", "content": prompt}
                ],
                max_tokens=max_tokens,
                temperature=temperature,
            )
            text = resp["choices"][0]["message"]["content"].strip()
            return {"provider": "openai", "model": model, "text": text}
    except Exception as e:
        # If first try fails, attempt a fallback to DEFAULT_OPENAI_FALLBACK using same detection
        try:
            fallback_model = DEFAULT_OPENAI_FALLBACK
            if hasattr(openai, "OpenAI"):
                client = openai.OpenAI(api_key=api_key)
                resp = client.chat.completions.create(
                    model=fallback_model,
                    messages=[
                        {"role": "system", "content": "You are a concise clinical summarizer."},
                        {"role": "user", "content": prompt}
                    ],
                    max_tokens=max_tokens,
                    temperature=temperature,
                )
                content = None
                try:
                    content = resp.choices[0].message.content
                except Exception:
                    content = resp["choices"][0]["message"]["content"] if isinstance(resp, dict) else str(resp)
                return {"provider": "openai", "model": fallback_model, "text": content}
            else:
                openai.api_key = api_key
                resp = openai.ChatCompletion.create(
                    model=fallback_model,
                    messages=[
                        {"role": "system", "content": "You are a concise clinical summarizer."},
                        {"role": "user", "content": prompt}
                    ],
                    max_tokens=max_tokens,
                    temperature=temperature,
                )
                text = resp["choices"][0]["message"]["content"].strip()
                return {"provider": "openai", "model": fallback_model, "text": text}
        except Exception as e2:
            return {"provider": "openai", "error": str(e)}

def call_claude(prompt, api_key=None, model=None, max_tokens=300, temperature=0.2):
    model = model or DEFAULT_CLAUDE_MODEL
    api_key = api_key or os.getenv("ANTHROPIC_API_KEY") or os.getenv("CLAUDE_API_KEY")
    if not api_key or Anthropic is None:
        return None
    client = Anthropic(api_key=api_key)
    try:
        full_prompt = HUMAN_PROMPT + prompt + AI_PROMPT
        resp = client.completions.create(
            model=model,
            prompt=full_prompt,
            max_tokens_to_sample=max_tokens,
            temperature=temperature,
        )
        text = resp["completion"].strip()
        return {"provider": "claude", "model": model, "text": text}
    except Exception as e:
        return {"provider": "claude", "error": str(e)}

def load_csv_first_row(path):
    if not os.path.exists(path):
        raise FileNotFoundError(f"CSV file not found: {path}")
    df = pd.read_csv(path)
    if df.shape[0] < 1:
        raise ValueError("CSV appears empty")
    return df.iloc[0].to_dict()

def run_report(csv_path, call_llm=True, openai_key=None, openai_model=None, claude_key=None, claude_model=None, save_path=None, json_mode=False, print_output=True):
    row = load_csv_first_row(csv_path)
    rows = build_feature_rows(row)
    cat_summary = category_summary(rows)
    report_text = build_report_text(rows, cat_summary)

    if print_output:
        print("\n" + "="*80)
        print("DETAILED PHYSIOMARKERS REPORT")
        print("="*80 + "\n")
        print(report_text)
        print("\n" + "="*80 + "\n")

    if save_path:
        if json_mode:
            out = {"report": report_text, "summary": cat_summary}
            with open(save_path, "w", encoding="utf-8") as f:
                json.dump(out, f, indent=2)
        else:
            with open(save_path, "w", encoding="utf-8") as f:
                f.write(report_text)
        if print_output:
            print(f"Report saved to: {save_path}")

    llm_outputs = {}
    if call_llm:
        prompt = create_prompt_for_llm(report_text)
        # OpenAI (if key available either from arg or env)
        if (openai_key or os.getenv("OPENAI_API_KEY")) and openai is not None:
            if print_output:
                print("Calling OpenAI...")
            res = call_openai(prompt, api_key=openai_key, model=openai_model)
            if res:
                llm_outputs["openai"] = res
                if print_output:
                    if "text" in res:
                        print(f"\n--- OpenAI ({res.get('model')}) concise interpretation ---\n{res['text']}\n")
                    else:
                        print(f"(OpenAI error: {res.get('error')})\n")
        else:
            if print_output:
                print("(OpenAI call skipped: API key or openai package missing.)")
        time.sleep(0.6)
        # Claude/Anthropic
        if (claude_key or os.getenv("ANTHROPIC_API_KEY") or os.getenv("CLAUDE_API_KEY")) and Anthropic is not None:
            if print_output:
                print("Calling Anthropic/Claude...")
            res = call_claude(prompt, api_key=claude_key, model=claude_model)
            if res:
                llm_outputs["claude"] = res
                if print_output:
                    if "text" in res:
                        print(f"\n--- Claude ({res.get('model')}) concise interpretation ---\n{res['text']}\n")
                    else:
                        print(f"(Claude error: {res.get('error')})\n")
        else:
            if print_output:
                print("(Claude call skipped: API key or anthropic package missing.)")
    return {"report": report_text, "category_summary": cat_summary, "llm": llm_outputs}

def print_example_usage():
    examples = [
        "python detailed_report_with_model_options.py",
        "python detailed_report_with_model_options.py --csv physiomarkers.csv --save report.txt",
        "export OPENAI_API_KEY='sk-...' && python detailed_report_with_model_options.py --openai-model gpt-4o-mini",
        "python detailed_report_with_model_options.py --openai-key sk-... --openai-model gpt-4o-mini",
        "python detailed_report_with_model_options.py --no-llm",
    ]
    print("Example commands:")
    for e in examples:
        print("  " + e)

def main(argv=None):
    parser = argparse.ArgumentParser(description="Generate a detailed physiomarkers report (single-row CSV).")
    parser.add_argument("--csv", "-c", default=DEFAULT_CSV, help="Path to physiomarkers CSV (single aggregated row).")
    parser.add_argument("--no-llm", action="store_true", help="Do not call LLMs, even if API keys are present.")
    parser.add_argument("--save", "-s", help="Save report to file (path). Use --json to save JSON.")
    parser.add_argument("--json", action="store_true", help="When used with --save, save as JSON (report+metadata).")
    parser.add_argument("--example", action="store_true", help="Print example usage and exit.")
    parser.add_argument("--quiet", action="store_true", help="Do not print report to stdout.")
    # New options for keys and models
    parser.add_argument("--openai-key", help="OpenAI API key (optional; prefer OPENAI_API_KEY env var).")
    parser.add_argument("--openai-model", default=DEFAULT_OPENAI_MODEL, help="OpenAI model to use (e.g., gpt-4o-mini).")
    parser.add_argument("--claude-key", help="Anthropic/Claude API key (optional; prefer ANTHROPIC_API_KEY env var).")
    parser.add_argument("--claude-model", default=DEFAULT_CLAUDE_MODEL, help="Claude model to use (e.g., claude-2.1).")
    args = parser.parse_args(argv)

    if args.example:
        print_example_usage()
        return 0

    # Warn about CLI-in-proc key usage
    if args.openai_key or args.claude_key:
        print("Warning: passing API keys on the command line can be visible to other processes/users. Consider using environment variables instead.")

    try:
        result = run_report(
            csv_path=args.csv,
            call_llm=(not args.no_llm),
            openai_key=args.openai_key,
            openai_model=args.openai_model,
            claude_key=args.claude_key,
            claude_model=args.claude_model,
            save_path=args.save,
            json_mode=args.json,
            print_output=(not args.quiet)
        )
        return 0
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return 2

if __name__ == "__main__":
    sys.exit(main())
