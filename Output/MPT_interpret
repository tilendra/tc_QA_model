2. Modified Code

```python
#!/usr/bin/env python3
"""
detailed_report.py

Reads an aggregated physiomarkers CSV (single-row), evaluates mapped features,
and prints a detailed textual report + category report-card. Optionally saves
the report and can call OpenAI / Anthropic (Claude) for a concise narrative
if API keys are configured.

Example command-line usage:
  python detailed_report.py
  python detailed_report.py --csv physiomarkers.csv --save report.txt
  python detailed_report.py --csv physiomarkers.csv --json --save report.json
  python detailed_report.py --no-llm
  python detailed_report.py --example

Environment:
  Set OPENAI_API_KEY and/or ANTHROPIC_API_KEY to enable LLM summarization.
Dependencies:
  pip install pandas
  Optional (for LLMs): pip install openai anthropic
"""
import os
import sys
import argparse
import json
import math
import time
import pandas as pd

# Optional LLM clients
try:
    import openai
except Exception:
    openai = None

try:
    from anthropic import Anthropic, HUMAN_PROMPT, AI_PROMPT
except Exception:
    Anthropic = None
    HUMAN_PROMPT = ""
    AI_PROMPT = ""

# Defaults
DEFAULT_CSV = "physiomarkers.csv"
OPENAI_MODEL = os.getenv("OPENAI_MODEL", "gpt-4")
OPENAI_FALLBACK = "gpt-3.5-turbo"
CLAUDE_MODEL = os.getenv("CLAUDE_MODEL", "claude-2.1")

# Small mapping of features -> (label, unit)
FEATURE_MAP = {
    "ECG_HR_bpm_mean": ("ECG mean heart rate", "bpm"),
    "ECG_T_rr_ms_mean": ("ECG mean RR interval", "ms"),
    "ECG_qt_interval_ms_mean": ("QT interval", "ms"),
    "ECG_qtc_interval_ms_mean": ("Corrected QT (QTc)", "ms"),
    "ECG_pr_interval_ms_mean": ("PR interval", "ms"),
    "ECG_QRS_duration_mean": ("QRS duration", "ms"),
    "HRV_HRV_SDNN": ("HRV SDNN (overall variability)", "ms"),
    "HRV_HRV_RMSSD": ("HRV RMSSD (short-term vagal)", "ms"),
    "HRV_HRV_pNN50": ("HRV pNN50 (fraction)", ""),
    "ABP_SBP_mean": ("Systolic blood pressure (mean)", "mmHg"),
    "ABP_DBP_mean": ("Diastolic blood pressure (mean)", "mmHg"),
    "ABP_MAP_mean": ("Mean arterial pressure (mean)", "mmHg"),
    "ABP_CO_mean": ("Cardiac output (mean)", "L/min"),
    "ABP_TPR_mean": ("Total peripheral resistance (mean)", "dyn·s/cm^5"),
    "ABP_ShockIndex_mean": ("Shock index (HR/SBP mean)", "ratio"),
    "RESP_resp_rate_Bpm_mean": ("Respiratory rate (mean)", "breaths/min"),
    "PPG_PR_mean": ("PPG pulse rate (mean)", "bpm"),
    "PPG_pat_ms_mean": ("Pulse arrival time (PAT mean)", "ms"),
    "PPG_SI_mean": ("PPG Stiffness Index (mean)", "unitless"),
    "PPG_RI_mean": ("PPG Reflection Index (mean)", "unitless"),
    "PPG_Augmentation_index_mean": ("PPG Augmentation Index (mean)", "%"),
}

# Approximate reference ranges (coarse)
NORMAL_RANGES = {
    "ECG_HR_bpm_mean": (60, 100, "Adult resting HR; context dependent"),
    "ECG_T_rr_ms_mean": (600, 1000, "RR in ms ≈ 60-100 bpm"),
    "ECG_qt_interval_ms_mean": (300, 450, "QT (ms) typical; depends on HR"),
    "ECG_qtc_interval_ms_mean": (None, 440, "QTc: >440 ms may be prolonged"),
    "ECG_pr_interval_ms_mean": (120, 200, "PR interval 120–200 ms"),
    "ECG_QRS_duration_mean": (0, 120, "QRS <120 ms normal"),
    "HRV_HRV_SDNN": (50, 150, "SDNN approx (context-dependent)"),
    "HRV_HRV_RMSSD": (20, 50, "RMSSD typical short-term"),
    "HRV_HRV_pNN50": (0.1, 0.4, "pNN50 fraction (approx)"),
    "ABP_SBP_mean": (90, 140, "Systolic BP approx normal range"),
    "ABP_DBP_mean": (60, 90, "Diastolic BP approx normal range"),
    "ABP_MAP_mean": (65, 110, "MAP for perfusion"),
    "ABP_CO_mean": (3.0, 7.0, "Cardiac output L/min"),
    "RESP_resp_rate_Bpm_mean": (12, 20, "Adult resting RR"),
    "PPG_PR_mean": (60, 100, "Pulse rate should roughly match ECG HR"),
    "PPG_pat_ms_mean": (180, 400, "Pulse arrival time varies by system"),
}

CATEGORY_PREFIXES = {
    "ECG_": "Cardiac / ECG",
    "HRV_": "Autonomic / HRV",
    "RESP_": "Respiratory",
    "ABP_": "Hemodynamics / Blood pressure",
    "PPG_": "Peripheral / PPG",
}

def get_category_for_feature(fid):
    for pfx, name in CATEGORY_PREFIXES.items():
        if fid.startswith(pfx):
            return name
    return "Other"

def evaluate_value(fid, val):
    if val is None:
        return "Missing", "No value"
    try:
        v = float(val)
    except Exception:
        return "Missing", "Non-numeric"
    if math.isnan(v):
        return "Missing", "NaN"

    if fid not in NORMAL_RANGES:
        return "Informational", "No approximate range available"

    low, high, note = NORMAL_RANGES[fid]
    if low is not None and high is not None:
        margin_low = low * 0.9 if low != 0 else low - 0.1
        margin_high = high * 1.1
        if low <= v <= high:
            return "Normal", note or ""
        if margin_low <= v < low or high < v <= margin_high:
            return "Borderline", f"Near threshold; {note or ''}"
        return "Abnormal", f"Outside typical range; {note or ''}"
    elif low is None and high is not None:
        if v <= high:
            return "Normal", note or ""
        if v <= high * 1.1:
            return "Borderline", f"Near high threshold; {note or ''}"
        return "Abnormal", f"Above expected; {note or ''}"
    elif low is not None and high is None:
        if v >= low:
            return "Normal", note or ""
        if v >= low * 0.9:
            return "Borderline", f"Near low threshold; {note or ''}"
        return "Abnormal", f"Below expected; {note or ''}"
    else:
        return "Informational", "No numeric range defined"

def build_implication(fid, value, status):
    if value is None or status == "Missing":
        return "Value not available."
    try:
        v = float(value)
    except Exception:
        return "Non-numeric value; cannot interpret."
    if fid == "ECG_HR_bpm_mean":
        if v < 50:
            return "Bradycardia range — correlate clinically (symptoms, meds)."
        if v > 110:
            return "Tachycardia — consider fever, pain, dehydration, arrhythmia."
        return "Rate within expected resting range."
    if fid == "RESP_resp_rate_Bpm_mean":
        if v < 10:
            return "Low respiratory rate — evaluate ventilatory status."
        if v > 24:
            return "Tachypnea — consider respiratory distress or metabolic cause."
        return "Respiratory rate within expected resting range."
    if fid in ("ECG_qt_interval_ms_mean", "ECG_qtc_interval_ms_mean"):
        if status == "Abnormal":
            return "Prolonged QT/QTc — consider drugs, electrolytes, clinical context."
        return "QT interval within referenced range."
    if fid == "ECG_QRS_duration_mean":
        if v >= 120:
            return "Wide QRS — consider conduction delay or bundle branch block."
        return "QRS duration within expected range."
    if fid in ("HRV_HRV_SDNN", "HRV_HRV_RMSSD", "HRV_HRV_pNN50"):
        if status == "Abnormal":
            return "Low HRV — may indicate reduced autonomic variability."
        return "HRV metric in expected range for short-term recording."
    if fid in ("PPG_SI_mean", "PPG_RI_mean", "PPG_Augmentation_index_mean", "PPG_pat_ms_mean"):
        return "Peripheral waveform index — interpret trend-wise and with device-specific norms."
    return "Interpret with clinical context."

def build_feature_rows(row):
    rows = []
    for fid, (label, unit) in FEATURE_MAP.items():
        raw = row.get(fid, None)
        if pd.isna(raw):
            raw = None
        status, note = evaluate_value(fid, raw)
        implication = build_implication(fid, raw, status)
        rows.append({
            "feature_id": fid,
            "label": label,
            "unit": unit,
            "value": raw,
            "status": status,
            "note": note,
            "implication": implication,
            "category": get_category_for_feature(fid),
        })
    return rows

def category_summary(rows):
    by_cat = {}
    for r in rows:
        by_cat.setdefault(r["category"], []).append(r)
    summaries = {}
    for cat, items in by_cat.items():
        total = len(items)
        abnormal = sum(1 for it in items if it["status"] == "Abnormal")
        borderline = sum(1 for it in items if it["status"] == "Borderline")
        missing = sum(1 for it in items if it["status"] == "Missing")
        score = (abnormal + 0.5 * borderline) / total if total > 0 else 0
        if score == 0:
            grade = "A"
        elif score <= 0.2:
            grade = "B"
        elif score <= 0.4:
            grade = "C"
        elif score <= 0.7:
            grade = "D"
        else:
            grade = "E"
        summaries[cat] = {
            "total": total, "abnormal": abnormal, "borderline": borderline,
            "missing": missing, "score": round(score, 3), "grade": grade
        }
    return summaries

def build_report_text(rows, cat_summary):
    lines = []
    lines.append("Clinical physiomarkers detailed report\n")
    lines.append("Note: reference ranges are approximate. This is a single aggregated row; correlate with clinical context and raw waveforms.\n")
    lines.append("Findings:")
    for r in rows:
        val_str = "N/A" if r["value"] is None else f"{r['value']}"
        unit = f" {r['unit']}" if r['unit'] else ""
        lines.append(f"- {r['label']} ({r['feature_id']}): {val_str}{unit} — {r['status']}. {r['implication']} ({r['note']})")
    lines.append("\nReport card (by category):")
    for cat, s in cat_summary.items():
        lines.append(f"- {cat}: Grade {s['grade']} (abnormal {s['abnormal']}/{s['total']}, borderline {s['borderline']}, score {s['score']})")
    lines.append("\nConcise interpretation (auto):")
    abn = [r for r in rows if r["status"] == "Abnormal"]
    bdr = [r for r in rows if r["status"] == "Borderline"]
    if abn:
        lines.append("- Key abnormal findings:")
        for t in abn[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    else:
        lines.append("- No strongly abnormal values detected in the mapped features.")
    if bdr:
        lines.append("- Borderline observations to watch:")
        for t in bdr[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    lines.append("\nSuggested next steps (non-urgent):")
    lines.append("1) Verify abnormal values against raw data and clinical context (ECG strips, waveform, cuff BP).")
    lines.append("2) Review medications and electrolytes if QT/QTc prolonged or HRV very low.")
    lines.append("3) Repeat measurement or monitor if hemodynamic instability suspected (MAP, Shock Index).")
    lines.append("\nUncertainty & limitations: single aggregated row; device-specific indices need population norms. Not a diagnosis.")
    return "\n".join(lines)

def create_prompt_for_llm(report_text):
    guidance = (
        "You are a clinical-style assistant. Using the structured report below, produce a concise interpretation "
        "in 4-6 short bullets — each: finding, implication, and degree of certainty (low/medium/high). "
        "Do NOT provide definitive diagnoses. Conclude with 2 recommended non-urgent next steps."
    )
    return f"Structured physiomarkers report:\n\n{report_text}\n\n{guidance}"

def call_openai(prompt, model=OPENAI_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("OPENAI_API_KEY")
    if not key or openai is None:
        return None
    openai.api_key = key
    try:
        resp = openai.ChatCompletion.create(
            model=model,
            messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                      {"role": "user", "content": prompt}],
            max_tokens=max_tokens, temperature=temperature
        )
        return {"model": model, "text": resp["choices"][0]["message"]["content"].strip()}
    except Exception:
        # fallback
        try:
            resp = openai.ChatCompletion.create(
                model=OPENAI_FALLBACK,
                messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                          {"role": "user", "content": prompt}],
                max_tokens=max_tokens, temperature=temperature
            )
            return {"model": OPENAI_FALLBACK, "text": resp["choices"][0]["message"]["content"].strip()}
        except Exception:
            return None

def call_claude(prompt, model=CLAUDE_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("ANTHROPIC_API_KEY")
    if not key or Anthropic is None:
        return None
    client = Anthropic(api_key=key)
    try:
        full_prompt = HUMAN_PROMPT + prompt + AI_PROMPT
        resp = client.completions.create(model=model, prompt=full_prompt, max_tokens_to_sample=max_tokens, temperature=temperature)
        return {"model": model, "text": resp["completion"].strip()}
    except Exception:
        return None

def save_report(report_text, path, json_mode=False, metadata=None):
    if json_mode:
        out = {"report": report_text}
        if metadata:
            out["metadata"] = metadata
        with open(path, "w", encoding="utf-8") as f:
            json.dump(out, f, indent=2)
    else:
        with open(path, "w", encoding="utf-8") as f:
            f.write(report_text)

def load_csv_first_row(path):
    if not os.path.exists(path):
        raise FileNotFoundError(f"CSV file not found: {path}")
    df = pd.read_csv(path)
    if df.shape[0] < 1:
        raise ValueError("CSV appears empty")
    return df.iloc[0].to_dict()

def run_report(csv_path, call_llm=True, save_path=None, json_mode=False, print_output=True):
    row = load_csv_first_row(csv_path)
    rows = build_feature_rows(row)
    cat_summary = category_summary(rows)
    report_text = build_report_text(rows, cat_summary)

    if print_output:
        print("\n" + "="*80)
        print("DETAILED PHYSIOMARKERS REPORT")
        print("="*80 + "\n")
        print(report_text)
        print("\n" + "="*80 + "\n")

    metadata = {"csv": os.path.abspath(csv_path), "generated_by": "detailed_report.py"}

    if save_path:
        save_report(report_text, save_path, json_mode=json_mode, metadata=metadata)
        if print_output:
            print(f"Report saved to: {save_path}")

    # Optional LLM summary
    llm_outputs = {}
    if call_llm:
        prompt = create_prompt_for_llm(report_text)
        if openai is not None and os.getenv("OPENAI_API_KEY"):
            if print_output:
                print("Calling OpenAI for concise interpretation...")
            res = call_openai(prompt)
            if res:
                llm_outputs["openai"] = res
                if print_output:
                    print(f"\n--- OpenAI ({res['model']}) concise interpretation ---\n")
                    print(res["text"])
        if Anthropic is not None and os.getenv("ANTHROPIC_API_KEY"):
            if print_output:
                print("\nCalling Anthropic/Claude for concise interpretation...")
            res = call_claude(prompt)
            if res:
                llm_outputs["claude"] = res
                if print_output:
                    print(f"\n--- Claude ({res['model']}) concise interpretation ---\n")
                    print(res["text"])
    return {"report": report_text, "category_summary": cat_summary, "llm": llm_outputs}

def print_example_usage():
    examples = [
        "python detailed_report.py",
        "python detailed_report.py --csv physiomarkers.csv --save report.txt",
        "python detailed_report.py --csv physiomarkers.csv --json --save report.json",
        "python detailed_report.py --no-llm",
        "export OPENAI_API_KEY='sk-...'  # then run to enable OpenAI summarization"
    ]
    print("Example commands:")
    for e in examples:
        print("  " + e)

def main(argv=None):
    parser = argparse.ArgumentParser(description="Generate a detailed physiomarkers report from a CSV (single aggregated row).")
    parser.add_argument("--csv", "-c", default=DEFAULT_CSV, help="Path to physiomarkers CSV (single aggregated row).")
    parser.add_argument("--no-llm", action="store_true", help="Do not call LLMs, even if API keys are present.")
    parser.add_argument("--save", "-s", help="Save report to file (path). Use --json to save JSON with metadata.")
    parser.add_argument("--json", action="store_true", help="When used with --save, save as JSON (report+metadata).")
    parser.add_argument("--example", action="store_true", help="Print example usage and exit.")
    parser.add_argument("--quiet", action="store_true", help="Do not print report to stdout (useful when saving only).")
    args = parser.parse_args(argv)

    if args.example:
        print_example_usage()
        return 0

    try:
        result = run_report(csv_path=args.csv, call_llm=(not args.no_llm), save_path=args.save, json_mode=args.json, print_output=(not args.quiet))
        return 0
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        return 2

if __name__ == "__main__":
    sys.exit(main())
