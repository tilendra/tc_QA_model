        status, note = evaluate_value(fid, raw)
        implication = build_implication(fid, raw, status)
        rows.append({
            "feature_id": fid,
            "label": label,
            "unit": unit,
            "value": raw,
            "status": status,
            "note": note,
            "implication": implication,
            "category": get_category_for_feature(fid),
        })
    return rows

def category_summary(rows):
    by_cat = {}
    for r in rows:
        by_cat.setdefault(r["category"], []).append(r)
    summaries = {}
    for cat, items in by_cat.items():
        total = len(items)
        abnormal = sum(1 for it in items if it["status"] == "Abnormal")
        borderline = sum(1 for it in items if it["status"] == "Borderline")
        missing = sum(1 for it in items if it["status"] == "Missing")
        score = (abnormal + 0.5 * borderline) / total if total > 0 else 0
        if score == 0:
            grade = "A"
        elif score <= 0.2:
            grade = "B"
        elif score <= 0.4:
            grade = "C"
        elif score <= 0.7:
            grade = "D"
        else:
            grade = "E"
        summaries[cat] = {
            "total": total, "abnormal": abnormal, "borderline": borderline,
            "missing": missing, "score": round(score, 3), "grade": grade
        }
    return summaries

def build_report_text(rows, cat_summary):
    lines = []
    lines.append("Clinical physiomarkers detailed report\n")
    lines.append("Note: reference ranges are approximate. This is a single aggregated row; correlate with clinical context and raw waveforms.\n")
    lines.append("Findings:")
    for r in rows:
        val_str = "N/A" if r["value"] is None else f"{r['value']}"
        unit = f" {r['unit']}" if r['unit'] else ""
        lines.append(f"- {r['label']} ({r['feature_id']}): {val_str}{unit} — {r['status']}. {r['implication']} ({r['note']})")
    lines.append("\nReport card (by category):")
    for cat, s in cat_summary.items():
        lines.append(f"- {cat}: Grade {s['grade']} (abnormal {s['abnormal']}/{s['total']}, borderline {s['borderline']}, score {s['score']})")
    lines.append("\nConcise interpretation (auto):")
    abn = [r for r in rows if r["status"] == "Abnormal"]
    bdr = [r for r in rows if r["status"] == "Borderline"]
    if abn:
        lines.append("- Key abnormal findings:")
        for t in abn[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    else:
        lines.append("- No strongly abnormal values detected in the mapped features.")
    if bdr:
        lines.append("- Borderline observations to watch:")
        for t in bdr[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    lines.append("\nSuggested next steps (non-urgent):")
    lines.append("1) Verify abnormal values against raw data and clinical context (ECG strips, waveform, cuff BP).")
    lines.append("2) Review medications and electrolytes if QT/QTc prolonged or HRV very low.")
    lines.append("3) Repeat measurement or monitor if hemodynamic instability suspected (MAP, Shock Index).")
    lines.append("\nUncertainty & limitations: single aggregated row; device-specific indices need population norms. Not a diagnosis.")
    return "\n".join(lines)

def create_prompt_for_llm(report_text):
    guidance = (
        "You are a clinical-style assistant. Using the structured report below, produce a concise interpretation "
        "in 4-6 short bullets — each: finding, implication, and degree of certainty (low/medium/high). "
        "Do NOT provide definitive diagnoses. Conclude with 2 recommended non-urgent next steps."
    )
    return f"Structured physiomarkers report:\n\n{report_text}\n\n{guidance}"

