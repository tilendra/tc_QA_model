    low, high, note = NORMAL_RANGES[fid]
    if low is not None and high is not None:
        margin_low = low * 0.9 if low != 0 else low - 0.1
        margin_high = high * 1.1
        if low <= v <= high:
            return "Normal", note or ""
        if margin_low <= v < low or high < v <= margin_high:
