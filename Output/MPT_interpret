#!/usr/bin/env python3
# Minimal example: read physiomarkers.csv, summarize key features, ask OpenAI + Anthropic (Claude) for concise interpretation.
# Requirements: pandas, openai, anthropic
# Install: pip install pandas openai anthropic

import os
import pandas as pd
import json
import time

# Optional: import OpenAI and Anthropic clients
try:
    import openai
except Exception:
    openai = None

try:
    from anthropic import Anthropic, HUMAN_PROMPT, AI_PROMPT
except Exception:
    Anthropic = None
    HUMAN_PROMPT = ""
    AI_PROMPT = ""

# CONFIG: path to CSV and which LLM models to call
CSV_PATH = "physiomarkers.csv"  # change as needed
OPENAI_MODEL = os.getenv("OPENAI_MODEL", "gpt-4")  # fallback to gpt-4 if available
OPENAI_FALLBACK = "gpt-3.5-turbo"
CLAUDE_MODEL = os.getenv("CLAUDE_MODEL", "claude-2.1")  # update to whichever Claude model you have access to

# A concise mapping of commonly interpreted features -> (readable name, units)
# Extend this dict with any features you want to include.
FEATURE_MAP = {
    "ECG_HR_bpm_mean": ("ECG mean heart rate", "bpm"),
    "ECG_T_rr_ms_mean": ("ECG mean RR interval", "ms"),
    "ECG_qt_interval_ms_mean": ("QT interval", "ms"),
    "ECG_qtc_interval_ms_mean": ("Corrected QT (QTc)", "ms"),
    "HRV_HRV_SDNN": ("HRV SDNN (overall variability)", "ms"),
    "HRV_HRV_RMSSD": ("HRV RMSSD (short-term vagal)", "ms"),
    "ABP_SBP_mean": ("Systolic blood pressure (mean)", "mmHg"),
    "ABP_DBP_mean": ("Diastolic blood pressure (mean)", "mmHg"),
    "ABP_MAP_mean": ("Mean arterial pressure", "mmHg"),
    "RESP_resp_rate_Bpm_mean": ("Respiratory rate (mean)", "breaths/min"),
    "PPG_PR_mean": ("PPG pulse rate (mean)", "bpm"),
    "PPG_SI_mean": ("PPG Stiffness Index (mean)", "dimensionless"),
    "PPG_RI_mean": ("PPG Reflection Index (mean)", "dimensionless"),
    "PPG_pat_ms_mean": ("Pulse arrival time (PAT mean)", "ms"),
    "PPG_Augmentation_index_mean": ("Augmentation index (mean)", "%"),
    # add more keys from the CSV as needed
}

# Helper: build human-readable summary for the selected features
def build_feature_summary(df_row, feature_map):
    lines = []
    found_any = False
    for fid, (label, unit) in feature_map.items():
        if fid in df_row:
            val = df_row[fid]
            # convert pd.NA / nan to string
            if pd.isna(val):
                display = "N/A"
            else:
                # Pretty formatting for floats/ints
                if isinstance(val, (float, int)):
                    display = f"{val:.3f}" if isinstance(val, float) else str(val)
                else:
                    display = str(val)
            lines.append(f"- {label} ({fid}) — {display} {unit}")
            found_any = True
    if not found_any:
        lines.append("(No mapped features were found in the CSV row. Expand FEATURE_MAP.)")
    return "\n".join(lines)

# Helper: create an LLM-friendly compact prompt
def create_prompt(summary_text, guidance=None, max_findings=6):
    guidance = guidance or (
        "You are a clinical-style assistant producing a concise (3-6 bullet) interpretation. "
        "Do NOT provide a definitive diagnosis. For each key finding, give 1 brief potential implication "
        "and the degree of certainty (low/medium/high). Then provide 2 suggested non-urgent next steps "
        "(e.g., repeat measurement, specific monitoring, clinical correlation). Keep the whole reply under ~200 words."
    )
    prompt = (
        "Patient physiomarkers: \n\n"
        f"{summary_text}\n\n"
        "Context: Use the provided single aggregated values. Interpret concisely. "
        f"{guidance}\n\n"
        "Return format: Plain text, short bullets. If a value is missing, note it. Mention uncertainties and limitations."
    )
    return prompt

# Call OpenAI ChatCompletion (Chat API)
def call_openai(prompt, model=OPENAI_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("OPENAI_API_KEY")
    if not key:
        print("OPENAI_API_KEY not set; skipping OpenAI call.")
        return None
    if openai is None:
        print("openai package not installed; skipping OpenAI call.")
        return None
    openai.api_key = key
    try:
        # Try preferred model, fallback to gpt-3.5-turbo if model not available
        resp = openai.ChatCompletion.create(
            model=model,
            messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                      {"role": "user", "content": prompt}],
            max_tokens=max_tokens,
            temperature=temperature,
        )
        text = resp["choices"][0]["message"]["content"].strip()
        return {"model": model, "text": text, "meta": resp}
    except Exception as e:
        print(f"OpenAI call failed for model {model}: {e}")
        if model != OPENAI_FALLBACK:
            print(f"Retrying with fallback model {OPENAI_FALLBACK} ...")
            try:
                resp = openai.ChatCompletion.create(
                    model=OPENAI_FALLBACK,
                    messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                              {"role": "user", "content": prompt}],
                    max_tokens=max_tokens,
                    temperature=temperature,
                )
                text = resp["choices"][0]["message"]["content"].strip()
                return {"model": OPENAI_FALLBACK, "text": text, "meta": resp}
            except Exception as e2:
                print(f"Fallback OpenAI call failed: {e2}")
        return None

# Call Anthropic / Claude via anthropic package
def call_claude(prompt, model=CLAUDE_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("ANTHROPIC_API_KEY")
    if not key:
        print("ANTHROPIC_API_KEY not set; skipping Claude call.")
        return None
    if Anthropic is None:
        print("anthropic package not installed; skipping Claude call.")
        return None
    client = Anthropic(api_key=key)
    try:
        # Use the HUMAN_PROMPT/AI_PROMPT wrapper if available
        full_prompt = HUMAN_PROMPT + prompt + AI_PROMPT
        resp = client.completions.create(
            model=model,
            prompt=full_prompt,
            max_tokens_to_sample=max_tokens,
            temperature=temperature,
        )
        text = resp["completion"].strip()
        return {"model": model, "text": text, "meta": resp}
    except Exception as e:
        print(f"Anthropic call failed: {e}")
        return None

def main():
    # Read CSV and get the first (and only) row of physiomarkers
    if not os.path.exists(CSV_PATH):
        print(f"CSV file not found: {CSV_PATH}. Provide the correct path.")
        return
    df = pd.read_csv(CSV_PATH)
    if df.shape[0] < 1:
        print("CSV appears empty.")
        return
    row = df.iloc[0].to_dict()

    # Build feature summary using our mapping
    summary = build_feature_summary(row, FEATURE_MAP)
    print("---- Compact feature summary sent to LLMs ----\n")
    print(summary)
    print("\n---------------------------------------------\n")

    # Create prompt
    prompt = create_prompt(summary)

    # Call OpenAI
    print("Calling OpenAI...")
    openai_result = call_openai(prompt)
    if openai_result:
        print(f"\n--- OpenAI ({openai_result['model']}) concise interpretation ---\n")
        print(openai_result["text"])
    else:
        print("\nOpenAI call skipped or failed.\n")

    # Small pause to avoid rate-limiting collisions
    time.sleep(0.8)

    # Call Claude (Anthropic)
    print("\nCalling Anthropic/Claude...")
    claude_result = call_claude(prompt)
    if claude_result:
        print(f"\n--- Claude ({claude_result['model']}) concise interpretation ---\n")
        print(claude_result["text"])
    else:
        print("\nClaude call skipped or failed.\n")

if __name__ == "__main__":
    main()
```

