2. Modified Code

```python
#!/usr/bin/env python3
"""
Read physiomarkers.csv (single aggregated row), evaluate a broader set of clinically-relevant features,
produce a detailed interpretation report and a short report-card by category, and optionally ask LLMs
(OpenAI / Anthropic) for a concise narrative.
Requirements: pandas, (optional) openai, (optional) anthropic
Install: pip install pandas openai anthropic
Set OPENAI_API_KEY and/or ANTHROPIC_API_KEY to enable LLM calls.
"""
import os
import pandas as pd
import time
import math

# Optional LLM clients
try:
    import openai
except Exception:
    openai = None

try:
    from anthropic import Anthropic, HUMAN_PROMPT, AI_PROMPT
except Exception:
    Anthropic = None
    HUMAN_PROMPT = ""
    AI_PROMPT = ""

CSV_PATH = "physiomarkers.csv"  # adjust as needed
OPENAI_MODEL = os.getenv("OPENAI_MODEL", "gpt-4")
OPENAI_FALLBACK = "gpt-3.5-turbo"
CLAUDE_MODEL = os.getenv("CLAUDE_MODEL", "claude-2.1")

# Map feature id -> (human label, unit)
FEATURE_MAP = {
    # ECG / rhythm
    "ECG_HR_bpm_mean": ("ECG mean heart rate", "bpm"),
    "ECG_T_rr_ms_mean": ("ECG mean RR interval", "ms"),
    # ECG intervals
    "ECG_qt_interval_ms_mean": ("QT interval", "ms"),
    "ECG_qtc_interval_ms_mean": ("Corrected QT (QTc)", "ms"),
    "ECG_pr_interval_ms_mean": ("PR interval", "ms"),
    "ECG_QRS_duration_mean": ("QRS duration", "ms"),
    "ECG_P_duration_mean": ("P-wave duration", "ms"),
    # Blood pressure / hemodynamics
    "ABP_SBP_mean": ("Systolic blood pressure (mean)", "mmHg"),
    "ABP_DBP_mean": ("Diastolic blood pressure (mean)", "mmHg"),
    "ABP_MAP_mean": ("Mean arterial pressure (mean)", "mmHg"),
    "ABP_ShockIndex_mean": ("Shock index (HR/SBP mean)", "ratio"),
    "ABP_CO_mean": ("Cardiac output (mean)", "L/min"),  # may be missing in many datasets
    "ABP_TPR_mean": ("Total peripheral resistance (mean)", "dyn·s/cm^5"),
    # Respiratory
    "RESP_resp_rate_Bpm_mean": ("Respiratory rate (mean)", "breaths/min"),
    # HRV / autonomic
    "HRV_HRV_SDNN": ("HRV SDNN (overall variability)", "ms"),
    "HRV_HRV_RMSSD": ("HRV RMSSD (short-term vagal)", "ms"),
    "HRV_HRV_pNN50": ("HRV pNN50 (fraction)", ""),  # sometimes 0..1 or percent
    # PPG / peripheral
    "PPG_PR_mean": ("PPG pulse rate (mean)", "bpm"),
    "PPG_pat_ms_mean": ("Pulse arrival time (PAT mean)", "ms"),
    "PPG_SI_mean": ("PPG Stiffness Index (mean)", "unitless"),
    "PPG_RI_mean": ("PPG Reflection Index (mean)", "unitless"),
    "PPG_Augmentation_index_mean": ("PPG Augmentation Index (mean)", "%"),
    # add or adjust as needed...
}

# Approximate clinical reference ranges (coarse). These are approximate and context dependent.
# Format: (low, high, note) where low/high can be None if not meaningful.
NORMAL_RANGES = {
    "ECG_HR_bpm_mean": (60, 100, "Adult resting HR; context dependent"),
    "ECG_T_rr_ms_mean": (600, 1000, "RR in ms ≈ 60-100 bpm"),
    "ECG_qt_interval_ms_mean": (300, 450, "QT (ms) typical range; depends on HR"),
    "ECG_qtc_interval_ms_mean": (None, 440, "QTc: >440 ms (approx) may be prolonged; sex-specific"),
    "ECG_pr_interval_ms_mean": (120, 200, "PR interval normal 120–200 ms"),
    "ECG_QRS_duration_mean": (0, 120, "QRS <120 ms normal; >120ms wide"),
    "ECG_P_duration_mean": (80, 120, "P-wave usually <120 ms"),
    "ABP_SBP_mean": (90, 140, "Systolic BP (approx normal range)"),
    "ABP_DBP_mean": (60, 90, "Diastolic BP (approx normal range)"),
    "ABP_MAP_mean": (65, 110, "Mean arterial pressure; perfusion depends on patient"),
    "ABP_ShockIndex_mean": (0.5, 0.7, "Shock Index (HR/SBP) typical 0.5-0.7; >0.9 concerning"),
    "ABP_CO_mean": (3.0, 7.0, "Cardiac output typical resting L/min"),
    "RESP_resp_rate_Bpm_mean": (12, 20, "Adult resting RR"),
    "HRV_HRV_SDNN": (50, 150, "Short-term SDNN approx; low values suggest reduced variability"),
    "HRV_HRV_RMSSD": (20, 50, "RMSSD typical short-term vagal marker"),
    "HRV_HRV_pNN50": (0.1, 0.4, "pNN50 fraction (approx); dataset may be percent or fraction"),
    "PPG_PR_mean": (60, 100, "Pulse rate should roughly match ECG HR"),
    "PPG_pat_ms_mean": (180, 400, "Pulse arrival time roughly 180–400 ms depending on system"),
    "PPG_SI_mean": (None, None, "Stiffness index is device/population dependent — interpret relative changes"),
    "PPG_RI_mean": (None, None, "Reflection index is relative; use for trends"),
    "PPG_Augmentation_index_mean": (-50, 50, "Augmentation indices vary by age; interpret with caution"),
}

# Category names by prefix for the short report card
CATEGORY_PREFIXES = {
    "ECG_": "Cardiac / ECG",
    "HRV_": "Autonomic / HRV",
    "RESP_": "Respiratory",
    "ABP_": "Hemodynamics / Blood pressure",
    "PPG_": "Peripheral / PPG",
}

def get_category_for_feature(fid):
    for pfx, name in CATEGORY_PREFIXES.items():
        if fid.startswith(pfx):
            return name
    return "Other"

def numeric_ok(val):
    return val is not None and (not (isinstance(val, float) and math.isnan(val)))

def evaluate_value(fid, val):
    """
    Return (status, note) where status in {"Normal","Borderline","Abnormal","Informational","Missing"}.
    Uses NORMAL_RANGES where available; if not available, returns Informational with note.
    """
    if val is None:
        return "Missing", "No value"
    try:
        v = float(val)
    except Exception:
        return "Missing", "Non-numeric"
    if math.isnan(v):
        return "Missing", "NaN"

    if fid not in NORMAL_RANGES:
        return "Informational", "No approximate range available; interpret in clinical context"

    low, high, note = NORMAL_RANGES[fid]
    # If both low and high are provided:
    if low is not None and high is not None:
        # tolerate slight rounding; define borderline windows (10% beyond range)
        margin_low = low * 0.9 if low != 0 else low - 0.1
        margin_high = high * 1.1
        if low <= v <= high:
            return "Normal", note or ""
        if margin_low <= v < low or high < v <= margin_high:
            return "Borderline", f"Near threshold; {note or ''}"
        return "Abnormal", f"Outside typical range; {note or ''}"
    elif low is None and high is not None:
        if v <= high:
            return "Normal", note or ""
        elif v <= high * 1.1:
            return "Borderline", f"Near high threshold; {note or ''}"
        else:
            return "Abnormal", f"Above expected; {note or ''}"
    elif low is not None and high is None:
        if v >= low:
            return "Normal", note or ""
        elif v >= low * 0.9:
            return "Borderline", f"Near low threshold; {note or ''}"
        else:
            return "Abnormal", f"Below expected; {note or ''}"
    else:
        return "Informational", "No numeric range defined"

def build_feature_rows(row):
    """Build list of dicts with evaluation for each mapped feature present in the row."""
    results = []
    for fid, (label, unit) in FEATURE_MAP.items():
        raw = row.get(fid, None)
        if pd.isna(raw):
            raw = None
        status, note = evaluate_value(fid, raw)
        # short plain-language implication
        implication = build_implication(fid, raw, status)
        results.append({
            "feature_id": fid,
            "label": label,
            "unit": unit,
            "value": raw,
            "status": status,
            "note": note,
            "implication": implication,
            "category": get_category_for_feature(fid),
        })
    return results

def build_implication(fid, value, status):
    """Return a one-line plain language implication for common features."""
    if value is None or status == "Missing":
        return "Value not available."
    try:
        v = float(value)
    except Exception:
        return "Non-numeric value; cannot interpret."
    # Simple heuristics
    if fid == "ECG_HR_bpm_mean":
        if v < 50:
            return "Bradycardia range — correlate clinically (symptoms, meds)."
        if v > 110:
            return "Tachycardia range — consider fever, pain, dehydration, arrhythmia."
        return "Rate within expected resting range."
    if fid == "RESP_resp_rate_Bpm_mean":
        if v < 10:
            return "Low respiratory rate — evaluate ventilatory status."
        if v > 24:
            return "Tachypnea — consider respiratory distress, metabolic acidosis, pain, fever."
        return "Respiratory rate within expected resting range."
    if fid in ("ABP_SBP_mean", "ABP_DBP_mean", "ABP_MAP_mean"):
        return "Hemodynamic measure — interpret together with symptoms and perfusion."
    if fid in ("ECG_qt_interval_ms_mean", "ECG_qtc_interval_ms_mean"):
        if status == "Abnormal":
            return "Prolonged QT/QTc — consider drug effects, electrolytes, and clinical context."
        return "QT interval within referenced range."
    if fid == "ECG_QRS_duration_mean":
        if v >= 120:
            return "Wide QRS — consider bundle branch block or conduction delay."
        return "QRS duration within expected range."
    if fid in ("HRV_HRV_SDNN", "HRV_HRV_RMSSD", "HRV_HRV_pNN50"):
        if status == "Abnormal":
            return "Low HRV — may indicate reduced autonomic variability; interpret with context."
        return "HRV metric in expected range for short-term recording."
    if fid == "PPG_pat_ms_mean":
        return "Pulse arrival time (surrogate for arterial stiffness and BP); interpret relative changes."
    if fid in ("PPG_SI_mean", "PPG_RI_mean", "PPG_Augmentation_index_mean"):
        return "Peripheral waveform index; interpret trend-wise and with device-specific norms."
    return "No specific implication coded; review in clinical context."

def category_summary(rows):
    """Compute simple counts and a grade for each category."""
    by_cat = {}
    for r in rows:
        cat = r["category"]
        by_cat.setdefault(cat, []).append(r)
    summaries = {}
    for cat, items in by_cat.items():
        total = len(items)
        abnormal = sum(1 for it in items if it["status"] == "Abnormal")
        borderline = sum(1 for it in items if it["status"] == "Borderline")
        informational = sum(1 for it in items if it["status"] == "Informational")
        missing = sum(1 for it in items if it["status"] == "Missing")
        # Derive a grade: A best -> E worst based on proportion abnormal+borderline
        score = (abnormal + 0.5 * borderline) / total if total > 0 else 0
        if score == 0:
            grade = "A"
        elif score <= 0.2:
            grade = "B"
        elif score <= 0.4:
            grade = "C"
        elif score <= 0.7:
            grade = "D"
        else:
            grade = "E"
        summaries[cat] = {
            "total": total,
            "abnormal": abnormal,
            "borderline": borderline,
            "informational": informational,
            "missing": missing,
            "score": round(score, 3),
            "grade": grade,
        }
    return summaries

def build_report_text(rows, cat_summary):
    """Create a textual report: header, per-feature lines, per-category card, and action items."""
    lines = []
    lines.append("Clinical physiomarkers detailed report\n")
    lines.append("Note: reference ranges are approximate. This is a single aggregated row; correlate with clinical context and raw waveforms.\n")
    # Per-feature details
    lines.append("Findings:")
    for r in rows:
        val_str = "N/A" if r["value"] is None else f"{r['value']}"
        unit = f" {r['unit']}" if r['unit'] else ""
        lines.append(f"- {r['label']} ({r['feature_id']}): {val_str}{unit} — {r['status']}. {r['implication']} ({r['note']})")
    lines.append("\nReport card (by category):")
    for cat, s in cat_summary.items():
        lines.append(f"- {cat}: Grade {s['grade']} (abnormal {s['abnormal']}/{s['total']}, borderline {s['borderline']}, score {s['score']})")
    # Top-level concise interpretation bullets (auto-derived)
    lines.append("\nConcise interpretation (auto):")
    # Identify the top 3 abnormal findings to highlight
    abn = [r for r in rows if r["status"] == "Abnormal"]
    bdr = [r for r in rows if r["status"] == "Borderline"]
    if abn:
        top = abn[:4]
        lines.append("- Key abnormal findings:")
        for t in top:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    else:
        lines.append("- No strongly abnormal values detected in the mapped features.")
    if bdr:
        lines.append("- Borderline observations to watch:")
        for t in bdr[:4]:
            lines.append(f"  • {t['label']}: {t['value']} {t['unit']} — {t['implication']}")
    # Suggested next steps (non-urgent standard suggestions)
    lines.append("\nSuggested next steps (non-urgent):")
    lines.append("1) Verify abnormal values against raw data and clinical context (ECG strips, bladder/arterial waveform, cuff/clinical BP).")
    lines.append("2) Review medications and electrolytes if QT/QTc prolonged or HRV very low.")
    lines.append("3) Repeat measurement or continuous monitoring if hemodynamic instability suspected (MAP, Shock Index).")
    lines.append("4) Consider targeted testing (12-lead ECG, ABG, labs) based on the top abnormal findings.")
    lines.append("\nUncertainty & limitations: single aggregated row; device-specific indices (PPG SI/RI, Augmentation Index) often need population-specific norms. Not a diagnosis.")
    return "\n".join(lines)

def create_prompt_for_llm(report_text, max_bullets=5):
    guidance = (
        "You are a clinical-style assistant. Using the structured report below, produce a concise interpretation in 4-6 short bullets "
        "— each bullet: finding, brief implication, and degree of certainty (low/medium/high). "
        "Do NOT provide definitive diagnoses. Conclude with 2 recommended non-urgent next steps. Keep result under ~200 words."
    )
    prompt = f"Structured physiomarkers report:\n\n{report_text}\n\n{guidance}"
    return prompt

# OpenAI / Anthropic wrappers (optional)
def call_openai(prompt, model=OPENAI_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("OPENAI_API_KEY")
    if not key or openai is None:
        print("(OpenAI not called: API key/package missing.)")
        return None
    openai.api_key = key
    try:
        resp = openai.ChatCompletion.create(
            model=model,
            messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                      {"role": "user", "content": prompt}],
            max_tokens=max_tokens,
            temperature=temperature,
        )
        text = resp["choices"][0]["message"]["content"].strip()
        return {"model": model, "text": text}
    except Exception as e:
        print(f"OpenAI call failed: {e}")
        # try fallback
        try:
            resp = openai.ChatCompletion.create(
                model=OPENAI_FALLBACK,
                messages=[{"role": "system", "content": "You are a concise clinical summarizer."},
                          {"role": "user", "content": prompt}],
                max_tokens=max_tokens,
                temperature=temperature,
            )
            text = resp["choices"][0]["message"]["content"].strip()
            return {"model": OPENAI_FALLBACK, "text": text}
        except Exception as e2:
            print(f"OpenAI fallback failed: {e2}")
            return None

def call_claude(prompt, model=CLAUDE_MODEL, max_tokens=300, temperature=0.2):
    key = os.getenv("ANTHROPIC_API_KEY")
    if not key or Anthropic is None:
        print("(Claude not called: API key/package missing.)")
        return None
    client = Anthropic(api_key=key)
    try:
        full_prompt = HUMAN_PROMPT + prompt + AI_PROMPT
        resp = client.completions.create(
            model=model,
            prompt=full_prompt,
            max_tokens_to_sample=max_tokens,
            temperature=temperature,
        )
        text = resp["completion"].strip()
        return {"model": model, "text": text}
    except Exception as e:
        print(f"Anthropic call failed: {e}")
        return None

def main():
    if not os.path.exists(CSV_PATH):
        print(f"CSV not found at {CSV_PATH}. Place physiomarkers.csv in the working directory or change CSV_PATH.")
        return
    df = pd.read_csv(CSV_PATH)
    if df.shape[0] < 1:
        print("CSV has no rows.")
        return
    row = df.iloc[0].to_dict()

    rows = build_feature_rows(row)
    cat_summary = category_summary(rows)
    report_text = build_report_text(rows, cat_summary)

    # Print the detailed report to stdout
    print("\n" + "="*80 + "\nDETAILED PHYSIOMARKERS REPORT\n" + "="*80 + "\n")
    print(report_text)
    print("\n" + "="*80 + "\nEND REPORT\n" + "="*80 + "\n")

    # Build a concise prompt and (optionally) call LLMs for a short narrative
    prompt = create_prompt_for_llm(report_text)
    print("Attempting optional LLM summarization (if API keys configured)...\n")

    # OpenAI
    openai_result = call_openai(prompt)
    if openai_result:
        print(f"--- OpenAI ({openai_result['model']}) concise interpretation ---\n")
        print(openai_result["text"])
    else:
        print("(OpenAI summary skipped or failed.)")

    time.sleep(0.7)

    # Claude / Anthropic
    claude_result = call_claude(prompt)
    if claude_result:
        print(f"\n--- Claude ({claude_result['model']}) concise interpretation ---\n")
        print(claude_result["text"])
    else:
        print("(Claude summary skipped or failed.)")

if __name__ == "__main__":
    main()
