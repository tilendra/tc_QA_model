def _extract_from_markdown_table(rows: List[List[str]]) -> Dict[str, str]:
    """
    Given a parsed markdown table rows (list of list of strings),
    returns a mapping {feature_name: description} if header-like
    columns exist. Flexible matching of 'feature'/'name' and
    'description'/'meaning'/'definition'.
    """
    if not rows:
        return {}
    header = [h.strip().lower() for h in rows[0]]
    def _find_col(candidates: List[str]) -> Optional[int]:
        for i, col in enumerate(header):
            for cand in candidates:
                if cand in col:
                    return i
        return None

    feat_idx = _find_col(["feature", "name", "variable", "field"])
    desc_idx = _find_col(["description", "meaning", "definition", "explanation", "notes"])

    contexts = {}
    if feat_idx is None or desc_idx is None:
        return contexts

    for r in rows[1:]:
        if feat_idx < len(r) and desc_idx < len(r):
            key = r[feat_idx].strip()
            val = r[desc_idx].strip()
            if key:
                contexts[key] = val
    return contexts


def parse_feature_context_md(md_text: str) -> Dict[str, str]:
    """
    Parse feature meanings from a markdown text. Supports:
    - Pipe tables starting with | and header row with 'Feature' and 'Description'-like columns
    - Fallback bullets like '- FEATURE: description' or '* FEATURE: description'
    - Fallback lines like 'FEATURE: description'
    Returns a dict {feature_name: description}.
    """
    contexts: Dict[str, str] = {}

    # First, attempt to parse pipe-style tables
    lines = md_text.splitlines()
    table_block: List[List[str]] = []
    in_table = False

    def flush_table():
        nonlocal contexts, table_block
        if table_block:
            # Remove separator rows (----)
            cleaned = []
            for row in table_block:
                if not all(set(c.strip()) <= set("-: ") for c in row):  # skip markdown separator line
                    cleaned.append(row)
            contexts.update(_extract_from_markdown_table(cleaned))
            table_block = []

    for line in lines:
        if line.strip().startswith("|"):
            # split on pipes
            cells = [c.strip() for c in line.strip().strip("|").split("|")]
            table_block.append(cells)
            in_table = True
        else:
            if in_table:
                flush_table()
                in_table = False
    flush_table()

    # Fallback: list-style "FEATURE: description"
    import re
    simple_pattern = re.compile(r"^[\-\*\s]*([A-Za-z0-9_\-\.]+)\s*:\s*(.+)$")
    for line in lines:
        m = simple_pattern.match(line.strip())
        if m:
            feature, desc = m.group(1).strip(), m.group(2).strip()
            if feature and feature not in contexts:
                contexts[feature] = desc

    return contexts


def load_feature_context(md_path: Optional[str]) -> Dict[str, str]:
    """
    Load and parse the modified_feature_table.md, returning a dict {feature: meaning}.
    If path is None or file not found, returns {}.
    """
    if not md_path:
        return {}
    if not os.path.isfile(md_path):
        print(f"[WARN] Feature meaning file not found at: {md_path}. Continuing without it.", file=sys.stderr)
        return {}
    try:
        with open(md_path, "r", encoding="utf-8") as f:
            md_text = f.read()
        ctx = parse_feature_context_md(md_text)
        if not ctx:
            print("[WARN] Could not parse any feature meanings from the md file.", file=sys.stderr)
        return ctx
    except Exception as e:
        print(f"[WARN] Failed to read/parse feature meaning md file: {e}", file=sys.stderr)
        return {}

