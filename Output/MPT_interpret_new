SYSTEM_PROMPT = (
    "You are a clinical data analyst. Using provided feature-meaning context and the physiomarker values from one patient, "
    "produce a concise, non-diagnostic interpretation. Avoid clinical claims; focus on data patterns, ranges, and potential "
    "physiological implications. Keep it brief."
)

def build_prompt(
    features: Dict[str, Any],
    feature_context: Dict[str, str],
    request_style: str = "concise"
) -> str:
    """
    Build user prompt content for the LLM, including any feature meanings found.
    """
    parts = []
    parts.append("Task:")
    if request_style == "concise":
        parts.append("- Provide a concise interpretation (5-8 bullets) plus a 1-sentence overall summary.")
    else:
        parts.append("- Provide a short interpretation and overall summary.")

    parts.append("\nFeature meanings (if available):")
    if feature_context:
        # Only include meanings for features we actually send
        to_include = {k: v for k, v in feature_context.items() if k in features}
        if not to_include:
            parts.append("- (No matching meanings found for the selected features in the provided context.)")
        else:
            for k, v in to_include.items():
                parts.append(f"- {k}: {v}")
    else:
        parts.append("- (No feature-meaning context available)")

    parts.append("\nPatient physiomarkers (selected):")
    for k, v in features.items():
        try:
            # Try to format floats compactly
            if isinstance(v, (float, int)):
                parts.append(f"- {k}: {float(v):.6g}")
            else:
                parts.append(f"- {k}: {v}")
        except Exception:
            parts.append(f"- {k}: {v}")

    parts.append("\nConstraints:")
    parts.append("- Do not provide medical advice.")
    parts.append("- Be specific but brief; avoid speculation beyond the data.")
    parts.append("- If values are inconsistent or missing, state that clearly.")

    return "\n".join(parts)

