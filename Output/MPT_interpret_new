def build_arg_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(description="Interpret physiomarkers for a patient with OpenAI/Claude using feature context.")
    p.add_argument("--csv", type=str, default=None, help="Path to physiomarkers.csv (single patient row).")
    p.add_argument("--feature-md", type=str, default="modified_feature_table.md", help="Path to feature meaning markdown file.")
    p.add_argument("--include-features", type=str, default=None, help="Comma-separated list of feature names to prioritize.")
    p.add_argument("--max-features", type=int, default=40, help="Max number of features to include in the prompt.")
    p.add_argument("--use-openai", action="store_true", help="Enable OpenAI model call.")
    p.add_argument("--use-anthropic", action="store_true", help="Enable Anthropic (Claude) model call.")
    p.add_argument("--openai-model", type=str, default="gpt-4o-mini", help="OpenAI model, e.g., gpt-4o-mini.")
    p.add_argument("--anthropic-model", type=str, default="claude-3-5-sonnet-20240620", help="Claude model, e.g., claude-3-5-sonnet-20240620.")
    p.add_argument("--openai-api-key", type=str, default=None, help="OpenAI API key (or set OPENAI_API_KEY env var).")
    p.add_argument("--anthropic-api-key", type=str, default=None, help="Anthropic API key (or set ANTHROPIC_API_KEY env var).")
    p.add_argument("--max-tokens-openai", type=int, default=500, help="Max tokens for OpenAI.")
    p.add_argument("--max-tokens-anthropic", type=int, default=600, help="Max tokens for Anthropic.")
    p.add_argument("--temperature", type=float, default=0.3, help="Sampling temperature.")
    p.add_argument("--print-prompt", action="store_true", help="Print prompt before results.")
    p.add_argument("--json", action="store_true", help="Print full JSON result.")
    return p

def main():
    args = build_arg_parser().parse_args()
    include = [s.strip() for s in args.include_features.split(",")] if args.include_features else None

    result = interpret_physio(
        input_csv=args.csv,
        df=None,
        feature_md=args.feature_md,
        include_features=include,
        max_features=args.max_features,
        use_openai=args.use_openai,
        use_anthropic=args.use_anthropic,
        openai_model=args.openai_model,
        anthropic_model=args.anthropic_model,
        openai_api_key=args.openai_api_key,
        anthropic_api_key=args.anthropic_api_key,
        max_tokens_openai=args.max_tokens_openai,
        max_tokens_anthropic=args.max_tokens_anthropic,
        temperature=args.temperature,
    )

    if args.print_prompt:
        print("\n=== Prompt sent to models ===")
        print(result["prompt"])
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        print("\n=== Selected Features (subset) ===")
        for k, v in result["selected_features"].items():
            try:
                print(f"- {k}: {float(v):.6g}")
            except Exception:
                print(f"- {k}: {v}")

        print("\n=== Model Outputs ===")
        for provider, text in result["outputs"].items():
            print(f"\n[{provider}]")
            print(text)

if __name__ == "__main__":
    main()
