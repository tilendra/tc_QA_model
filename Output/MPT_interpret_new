    "ECG_QRS_duration_mean",
    "ECG_pr_interval_ms_mean",
]

def _pick_available_features(row: pd.Series, include: Optional[List[str]] = None, max_features: int = 40) -> Dict[str, Any]:
    """
    Pick a curated subset of features present in the row. If include is provided,
    it is used preferentially; otherwise DEFAULT_KEY_FEATURES is used.
    """
    features = include if include else DEFAULT_KEY_FEATURES
    picked = {}
    for k in features:
        if k in row.index and pd.notna(row[k]):
            picked[k] = row[k]
    # If we still have room, add some derived/common fallbacks that exist in the row
    if len(picked) < max_features:
        extras = []
        for prefix in ["ECG_", "PPG_", "RESP_", "ABP_", "HRV_"]:
            extras.extend([c for c in row.index if c.startswith(prefix)])
        for c in extras:
            if c not in picked and pd.notna(row[c]):
                picked[c] = row[c]
                if len(picked) >= max_features:
                    break
    return picked

# ---------------------------
# Prompt building
# ---------------------------

SYSTEM_PROMPT = (
    "You are a clinical data analyst. Using provided feature-meaning context and the physiomarker values from one patient, "
    "produce a concise, non-diagnostic interpretation. Avoid clinical claims; focus on data patterns, ranges, and potential "
    "physiological implications. Keep it brief."
)

def build_prompt(
    features: Dict[str, Any],
    feature_context: Dict[str, str],
    request_style: str = "concise"
) -> str:
    """
    Build user prompt content for the LLM, including any feature meanings found.
    """
    parts = []
    parts.append("Task:")
    if request_style == "concise":
        parts.append("- Provide a concise interpretation (5-8 bullets) plus a 1-sentence overall summary.")
    else:
        parts.append("- Provide a short interpretation and overall summary.")

    parts.append("\nFeature meanings (if available):")
    if feature_context:
        to_include = {k: v for k, v in feature_context.items() if k in features}
        if not to_include:
            parts.append("- (No matching meanings found for the selected features in the provided context.)")
        else:
            for k, v in to_include.items():
                parts.append(f"- {k}: {v}")
    else:
        parts.append("- (No feature-meaning context available)")

    parts.append("\nPatient physiomarkers (selected):")
    for k, v in features.items():
        try:
            if isinstance(v, (float, int)):
                parts.append(f"- {k}: {float(v):.6g}")
            else:
                parts.append(f"- {k}: {v}")
        except Exception:
            parts.append(f"- {k}: {v}")

    parts.append("\nConstraints:")
    parts.append("- Do not provide medical advice.")
    parts.append("- Be specific but brief; avoid speculation beyond the data.")
    parts.append("- If values are inconsistent or missing, state that clearly.")

    return "\n".join(parts)

# ---------------------------
# LLM callers
# ---------------------------

def call_openai_chat(
    prompt: str,
    model: str = "gpt-4o-mini",
    api_key: Optional[str] = None,
    max_tokens: int = 500,
    temperature: float = 0.3,
) -> str:
    """
    Call OpenAI Chat API. Requires openai>=1.0.0 package installed.
    """
    try:
        from openai import OpenAI
    except Exception as e:
        return f"[ERROR] openai package not installed: {e}"

    client = OpenAI(api_key=api_key or os.getenv("OPENAI_API_KEY"))
    if not (api_key or os.getenv("OPENAI_API_KEY")):
        return "[ERROR] OPENAI_API_KEY not set. Please export it or pass api_key."

    try:
        resp = client.chat.completions.create(
            model=model,
            messages=[
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": prompt},
            ],
            max_tokens=max_tokens,
            temperature=temperature,
        )
        return resp.choices[0].message.content
    except Exception as e:
        return f"[ERROR] OpenAI call failed: {e}"


def call_anthropic_messages(
    prompt: str,
    model: str = "claude-3-5-sonnet-20240620",
    api_key: Optional[str] = None,
    max_tokens: int = 600,
    temperature: float = 0.3,
) -> str:
    """
    Call Anthropic Messages API (Claude 3.x). Requires anthropic package installed.
    """
    try:
        import anthropic
    except Exception as e:
        return f"[ERROR] anthropic package not installed: {e}"

    client = anthropic.Anthropic(api_key=api_key or os.getenv("ANTHROPIC_API_KEY"))
    if not (api_key or os.getenv("ANTHROPIC_API_KEY")):
        return "[ERROR] ANTHROPIC_API_KEY not set. Please export it or pass api_key."

    try:
        resp = client.messages.create(
            model=model,
            max_tokens=max_tokens,
            temperature=temperature,
            system=SYSTEM_PROMPT,
            messages=[{"role": "user", "content": prompt}],
        )
        text_parts = []
        for blk in resp.content:
            if blk.type == "text":
                text_parts.append(blk.text)
        return "\n".join(text_parts).strip() if text_parts else "[WARN] Empty Claude response."
    except Exception as e:
        return f"[ERROR] Anthropic call failed: {e}"

# ---------------------------
# Emoji post-processing
# ---------------------------

_EMOJI_CONTEXT_RULES: List[Tuple[re.Pattern, str]] = [
    (re.compile(r"\b(ecg|heart rate|hr\b|qrs|qt[c]?)\b", re.I), "❤️"),
    (re.compile(r"\b(hrv|variability|sdnn|rmssd|lfhf|lfn|hfn)\b", re.I), "📊"),
    (re.compile(r"\b(resp|breath|ventilat|inspir|expir|rr\b)\b", re.I), "🫁"),
    (re.compile(r"\b(blood pressure|sbp|dbp|map|abp|shock index|tpr|co\b)\b", re.I), "🩸"),
    (re.compile(r"\b(ppg|pulse|photopleth|augmentation)\b", re.I), "📟"),
]

_EMOJI_STATUS_RULES: List[Tuple[re.Pattern, str]] = [
    (re.compile(r"\b(elevated|high|increased|tachy|above (?:ref|range)|rise|rising)\b", re.I), "⬆️"),
    (re.compile(r"\b(low|decreased|reduced|brady|below (?:ref|range)|drop|falling)\b", re.I), "⬇️"),
    (re.compile(r"\b(normal|within (?:range|typical)|stable|unchanged|consistent)\b", re.I), "✅"),
    (re.compile(r"\b(missing|incomplete|inconsistent|noisy|artifact|artifacts|uncertain|caution)\b", re.I), "⚠️"),
]

_SUMMARY_RULE = re.compile(r"^\s*(overall|summary)\b", re.I)

def _annotate_line_with_emojis(line: str) -> str:
    base = line.rstrip("\n")
    if not base.strip():
        return base
    # Identify bullet-like content
    bullet_prefix = ""
    stripped = base.lstrip()
    if stripped.startswith(("- ", "* ", "• ")):
        # Preserve original left spaces and prefix
        left_spaces = base[:len(base) - len(stripped)]
        bullet_prefix = stripped[:2]
        content = stripped[2:].strip()
        emojis: List[str] = []
        # Context emojis
        for pat, emo in _EMOJI_CONTEXT_RULES:
            if pat.search(content):
                emojis.append(emo)
        # Status emojis
        for pat, emo in _EMOJI_STATUS_RULES:
            if pat.search(content):
                emojis.append(emo)
        # Fallback if no context/status found but is a bullet
        if not emojis:
            emojis.append("•")
        return f"{left_spaces}{bullet_prefix}{' '.join(emojis)} {content}"
    # Summary or other lines
    if _SUMMARY_RULE.search(stripped):
        return f"🧾 {base}"
    return base

def add_emojis_to_report(text: str) -> str:
    """
    Add context-aware emojis to each line of a model's report.
    """
    if not isinstance(text, str) or text.startswith("[ERROR]") or text.startswith("[WARN]"):
        return text
    lines = text.splitlines()
    return "\n".join(_annotate_line_with_emojis(ln) for ln in lines)

def build_combined_report(
    emoji_outputs: Dict[str, str],
    openai_model: Optional[str],
    anthropic_model: Optional[str],
    title: Optional[str] = None
) -> str:
    """
    Build a simple text report combining emoji-enhanced outputs.
    """
    title_line = title or "Physiomarker Interpretation Report ✨"
    parts = [title_line]
    if "openai" in emoji_outputs:
        parts.append("")
        parts.append(f"== OpenAI ({openai_model}) ==" if openai_model else "== OpenAI ==")
        parts.append(emoji_outputs["openai"])
    if "anthropic" in emoji_outputs:
        parts.append("")
        parts.append(f"== Anthropic ({anthropic_model}) ==" if anthropic_model else "== Anthropic ==")
        parts.append(emoji_outputs["anthropic"])
    return "\n".join(parts).strip()

def save_text_report(text: str, path: Optional[str]) -> Optional[str]:
    if not path:
        return None
    try:
        # If a directory is provided, create a timestamped file in it
        if os.path.isdir(path):
            ts = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"physio_report_{ts}.md"
            path = os.path.join(path, filename)
        os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(text)
        return path
    except Exception as e:
        print(f"[WARN] Failed to save report to {path}: {e}", file=sys.stderr)
        return None

# ---------------------------
# Main interpreter
# ---------------------------

def _single_row_from_df(df: pd.DataFrame) -> pd.Series:
    if df.shape[0] == 0:
        raise ValueError("Input DataFrame has 0 rows.")
    if df.shape[0] > 1:
        print(f"[INFO] DataFrame has {df.shape[0]} rows. Using the first row for interpretation.", file=sys.stderr)
    return df.iloc[0]


def interpret_physio(
    input_csv: Optional[str] = None,
    df: Optional[pd.DataFrame] = None,
    feature_md: Optional[str] = None,
    include_features: Optional[List[str]] = None,
    max_features: int = 40,
    use_openai: bool = True,
    use_anthropic: bool = True,
    openai_model: str = "gpt-4o-mini",
    anthropic_model: str = "claude-3-5-sonnet-20240620",
    openai_api_key: Optional[str] = None,
    anthropic_api_key: Optional[str] = None,
    max_tokens_openai: int = 500,
    max_tokens_anthropic: int = 600,
    temperature: float = 0.3,
    save_report_path: Optional[str] = None,
    add_emojis: bool = True,
) -> Dict[str, Union[str, Dict[str, Any]]]:
    """
    Interpret a physiomarkers row using LLMs with feature meaning context.
    - If input_csv is provided, it is used.
    - Else, the provided df argument is used.
    Returns dict with prompt, selected_features, raw model outputs,
    emoji-enhanced outputs, and optional saved report path.
    """
    if input_csv is None and df is None:
        raise ValueError("Provide input_csv or df.")

    if df is None:
        df = pd.read_csv(input_csv)

    row = _single_row_from_df(df)
    picked = _pick_available_features(row, include=include_features, max_features=max_features)

    feature_context = load_feature_context(feature_md)
    prompt = build_prompt(picked, feature_context, request_style="concise")

    outputs: Dict[str, str] = {}
    if use_openai:
        outputs["openai"] = call_openai_chat(
            prompt=prompt,
            model=openai_model,
            api_key=openai_api_key,
            max_tokens=max_tokens_openai,
            temperature=temperature,
        )
    if use_anthropic:
        outputs["anthropic"] = call_anthropic_messages(
            prompt=prompt,
            model=anthropic_model,
            api_key=anthropic_api_key,
            max_tokens=max_tokens_anthropic,
            temperature=temperature,
        )

    emoji_outputs: Dict[str, str] = {}
    if add_emojis:
        for provider, text in outputs.items():
            emoji_outputs[provider] = add_emojis_to_report(text)
    else:
        emoji_outputs = outputs.copy()

    report_text = build_combined_report(
        emoji_outputs=emoji_outputs,
        openai_model=openai_model if use_openai else None,
        anthropic_model=anthropic_model if use_anthropic else None,
        title="Physiomarker Interpretation Report ✨"
    )
    saved_path = save_text_report(report_text, save_report_path) if save_report_path else None

    return {
        "prompt": prompt,
        "selected_features": picked,
        "outputs": outputs,
        "emoji_outputs": emoji_outputs,
        "report_text": report_text,
        "report_path": saved_path or "",
    }

def interpret_physio_from_df(
    df: pd.DataFrame,
    feature_md: Optional[str] = None,
    include_features: Optional[List[str]] = None,
    **kwargs
) -> Dict[str, Union[str, Dict[str, Any]]]:
    return interpret_physio(
        input_csv=None,
        df=df,
        feature_md=feature_md,
        include_features=include_features,
        **kwargs
    )

