def _pick_available_features(row: pd.Series, include: Optional[List[str]] = None, max_features: int = 40) -> Dict[str, Any]:
    """
    Pick a curated subset of features present in the row. If include is provided,
    it is used preferentially; otherwise DEFAULT_KEY_FEATURES is used.
    """
    features = include if include else DEFAULT_KEY_FEATURES
    picked = {}
    for k in features:
        if k in row.index and pd.notna(row[k]):
            picked[k] = row[k]
    # If we still have room, add some derived/common fallbacks that exist in the row
    if len(picked) < max_features:
        extras = []
        # Some likely useful extras by prefix
        for prefix in ["ECG_", "PPG_", "RESP_", "ABP_", "HRV_"]:
            extras.extend([c for c in row.index if c.startswith(prefix)])
        # Keep stable order, add a few not already included
        for c in extras:
            if c not in picked and pd.notna(row[c]):
                picked[c] = row[c]
                if len(picked) >= max_features:
                    break
    return picked

