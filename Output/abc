            plt.savefig(os.path.join(out_dir, f'cluster_{int(c)}_modstat_bar.png'), dpi=200)
            plt.close()
        except Exception:
            pass

    # Boxplots for union of top features across clusters
    union_features = set()
    for c in clusters:
        union_features.update(list(interpretations[int(c)]['top_positive_features'].keys()))
        union_features.update(list(interpretations[int(c)]['top_negative_features'].keys()))
    union_features = [f for f in feature_columns if f in union_features]
    if union_features:
        try:
            n_col = min(6, len(union_features))
            plt.figure(figsize=(max(8, 2*n_col), 4*int(np.ceil(len(union_features)/n_col))))
            for i, feat in enumerate(union_features):
                plt.subplot(int(np.ceil(len(union_features)/n_col)), n_col, i+1)
                sns.boxplot(x=labels, y=X[feat], palette='Set2')
                plt.title(feat)
                plt.xlabel('Cluster')
                plt.tight_layout()
            plt.suptitle('Distribution of Top Distinguishing Features by Cluster', y=1.02)
            plt.savefig(os.path.join(out_dir, 'top_features_boxplots.png'), dpi=200, bbox_inches='tight')
            plt.close()
        except Exception:
            pass

    print(f"Saved interpretation files to '{out_dir}'.")
    for c in sorted(interpretations.keys()):
        print(interpretations[c]['text_summary'].splitlines()[0])  # single-line summary

    # If requested, call an LLM to refine phenotype names & descriptions
    if call_llm:
        try:
            llm_results = _call_llm_for_interpretations(
                interpretations=interpretations,
                out_dir=out_dir,
                provider=llm_provider,
                model=llm_model,
                max_tokens=llm_max_tokens,
                temperature=llm_temperature,
                system_prompt=llm_system_prompt,
                save_response=llm_save_response
            )
            # Merge LLM outputs into interpretations
            for cid, rr in llm_results.items():
                interpretations[int(cid)]['llm_refinement'] = rr
            # save updated interpretations
            with open(os.path.join(out_dir, 'cluster_interpretations_with_llm.json'), 'w') as f:
                json.dump(interpretations, f, indent=2)
            print(f"Saved LLM refinements to '{os.path.join(out_dir, 'cluster_interpretations_with_llm.json')}'.")
        except Exception as e:
            print("LLM refinement failed:", e)

    return interpretations


def _call_llm_for_interpretations(interpretations, out_dir='cluster_interpretation',
                                  provider='openai', model=None,
                                  max_tokens=None, temperature=None,
                                  system_prompt=None, save_response=True,
                                  request_delay=0.5):
    """
    Send compact cluster summaries to an LLM to request refined names, short clinical descriptions,
    and concise distinguishing feature lists.

    Provider: 'openai' or 'anthropic'
    Model: string name. Temperature and max_tokens default selection happens here.
    """

    # Helper: choose sensible defaults for temperature and max_tokens per model family
    def _choose_defaults(model_name, provided_temp, provided_max_tokens):
        m = (model_name or "").lower()
        # Default temps: creative for gpt-5/gpt-5-mini; conservative for others
        if provided_temp is not None:
            temp = provided_temp
        elif 'gpt-5' in m or 'gpt-5-mini' in m:
            temp = 1.0
        elif 'gpt' in m:
            temp = 0.2
        elif 'claude' in m or 'anthropic' in m:
            temp = 0.3
        else:
            temp = 0.25

        # defaults for max tokens
        if provided_max_tokens is not None:
            max_t = provided_max_tokens
        elif 'gpt-5' in m:
            max_t = 1600
        elif 'gpt-5-mini' in m:
            max_t = 800
        elif 'gpt' in m:
            max_t = 1024
        elif 'claude' in m:
            max_t = 1200
        else:
            max_t = 800
        return float(temp), int(max_t)

    temp, max_toks = _choose_defaults(model, temperature, max_tokens)

    # Build compact prompt for each cluster: include short cluster lines only (name, top pos/neg, mod-stat top 5)
    cluster_texts = {}
    for cid, info in interpretations.items():
        lines = []
        lines.append(f"Cluster {cid} (n={info['count']}, {info['percent']:.1f}%):")
        lines.append(f"Current name: {info.get('phenotype_name', '')}")
        lines.append("Top positive features:")
        for feat, z in list(info['top_positive_features'].items())[:6]:
            lines.append(f"  - {feat}: z={z:.2f}")
        lines.append("Top negative features:")
        for feat, z in list(info['top_negative_features'].items())[:6]:
            lines.append(f"  - {feat}: z={z:.2f}")
        # Add top modality-stat entries
        ms = info.get('modality_stat_meanz', {})
        ms_items = sorted(ms.items(), key=lambda kv: kv[1], reverse=True)[:6]
        if ms_items:
            lines.append("Modalities/stats (mean z):")
            for (mod, stat), v in ms_items:
                lines.append(f"  - {mod}-{stat}: {v:.2f}")
        cluster_texts[cid] = "\n".join(lines)

    # Compose a single instruction asking for structured outputs per cluster
    instruction = textwrap.dedent("""\
        You are an expert critical care clinician and clinical data scientist.
        For each input cluster summary, produce:
         1) A concise phenotype name (<= 5 words).
         2) A 1-sentence clinical description (what is distinctive, plausible physiologic interpretation).
         3) A bullet list of 3 key distinguishing features (short).
         4) One short clinical implication or suggested interpretation (1 line).
        Return output in JSON mapping cluster id -> {name, description, key_features, implication}.
        Keep answers brief and machine-parseable. If uncertain, indicate 'uncertain' in the implication.
        """)

    if system_prompt:
        system_prompt = system_prompt.strip()
    else:
        system_prompt = "You are a helpful, concise clinical phenotyping assistant."

    # Build the combined user content (but keep it compact)
    user_content_lines = [instruction, ""]
    for cid, ct in cluster_texts.items():
        user_content_lines.append(f"### CLUSTER {cid}\n{ct}\n")
    user_content = "\n".join(user_content_lines)

    # If content is extremely large, trim per-cluster details to essential lines
    approx_len = len(user_content.split())
    if approx_len > 4000:
        # reduce details: only keep top 3 positive and top 3 negative features
        user_content_lines = [instruction, ""]
        for cid, info in interpretations.items():
            lines = []
            lines.append(f"Cluster {cid} (n={info['count']}, {info['percent']:.1f}%):")
            lines.append(f"Current name: {info.get('phenotype_name', '')}")
            lines.append("Top positive features:")
            for feat, z in list(info['top_positive_features'].items())[:3]:
                lines.append(f"  - {feat}: z={z:.2f}")
            lines.append("Top negative features:")
            for feat, z in list(info['top_negative_features'].items())[:3]:
                lines.append(f"  - {feat}: z={z:.2f}")
            user_content_lines.append("\n".join(lines))
        user_content = "\n".join(user_content_lines)

    # Prepare provider-specific calls
    results = {}
    timestamp = int(time.time())

    if provider.lower() == 'openai':
        if openai is None:
            raise RuntimeError("openai package not available. Install with `pip install openai` and set OPENAI_API_KEY.")
        api_key = os.environ.get('OPENAI_API_KEY')
        if not api_key:
            raise RuntimeError("OPENAI_API_KEY not found in environment variables.")
        openai.api_key = api_key

        # Build chat messages
        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_content}
        ]
        # Use ChatCompletion
        model_name = model or "gpt-4o"  # fallback
        try:
            resp = openai.ChatCompletion.create(
                model=model_name,
                messages=messages,
                temperature=temp,
                max_tokens=max_toks,
                n=1
            )
            text = resp['choices'][0]['message']['content']
            if save_response:
                with open(os.path.join(out_dir, f'llm_response_openai_{model_name}_{timestamp}.txt'), 'w') as f:
                    f.write(text)
                with open(os.path.join(out_dir, f'llm_response_openai_{model_name}_{timestamp}.json'), 'w') as f:
                    json.dump(resp, f, indent=2)
            # Try to parse as JSON; if not valid, return raw text under a special key
            try:
                parsed = json.loads(text)
                results = {int(k): v for k, v in parsed.items()}
            except Exception:
                # attempt to extract JSON-like block
                import re
                m = re.search(r'\{.*\}', text, re.S)
                if m:
                    try:
                        parsed = json.loads(m.group(0))
                        results = {int(k): v for k, v in parsed.items()}
                    except Exception:
                        results = {'_raw': text}
                else:
                    results = {'_raw': text}
        except Exception as e:
            raise RuntimeError(f"OpenAI API request failed: {e}")

    elif provider.lower() in ('anthropic', 'claude'):
        # Anthropic / Claude
        if Anthropic is None:
            raise RuntimeError("anthropic package not available. Install with `pip install anthropic` and set ANTHROPIC_API_KEY.")
        api_key = os.environ.get('ANTHROPIC_API_KEY')
        if not api_key:
            raise RuntimeError("ANTHROPIC_API_KEY not found in environment variables.")
        client = Anthropic(api_key=api_key)
        # Construct prompt according to Anthropic API style: system + user content
        prompt = f"{system_prompt}\n\n{user_content}\n\nPlease answer in JSON."
        model_name = model or "claude-2.1"
        try:
            resp = client.completions.create(
                model=model_name,
                prompt=prompt,
                max_tokens_to_sample=max_toks,
                temperature=float(temp)
            )
            text = resp["completion"]
            if save_response:
                with open(os.path.join(out_dir, f'llm_response_anthropic_{model_name}_{timestamp}.txt'), 'w') as f:
                    f.write(text)
                with open(os.path.join(out_dir, f'llm_response_anthropic_{model_name}_{timestamp}.json'), 'w') as f:
                    json.dump(resp, f, indent=2)
            try:
                parsed = json.loads(text)
                results = {int(k): v for k, v in parsed.items()}
            except Exception:
                # fallback raw
                results = {'_raw': text}
        except Exception as e:
            raise RuntimeError(f"Anthropic API request failed: {e}")

    else:
        raise ValueError("Unsupported LLM provider. Choose 'openai' or 'anthropic'/'claude'.")

    # If the LLM returned a raw string, attempt to split by cluster markers heuristically
    if results and isinstance(results, dict) and '_raw' in results:
        raw_text = results['_raw']
        # Heuristic parsing: find cluster headings and collect following lines
        parsed_map = {}
        lines = raw_text.splitlines()
        current = None
        buffer = []
        for ln in lines:
            ln_strip = ln.strip()
            if ln_strip.lower().startswith('cluster'):
                # flush previous
                if current is not None:
                    parsed_map[current] = "\n".join(buffer).strip()
                # set new
                parts = ln_strip.split()
                # attempt to get cluster id
                try:
                    cid = int(parts[1].strip(':'))
                except Exception:
                    cid = '_unknown'
                current = cid
                buffer = [ln_strip]
            else:
                if current is None:
                    continue
                buffer.append(ln)
        if current is not None:
            parsed_map[current] = "\n".join(buffer).strip()
        # store as text descriptions per cluster
        results = {}
        for k, v in parsed_map.items():
            results[int(k) if isinstance(k, int) else k] = {'raw_text': v}

    # Return the results mapping cluster -> refinement
    return results
