import os
import json
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.stats import skew
from collections import defaultdict

def interpret_sepsis_phenotypes(df_data, feature_columns, cluster_labels,
                                out_dir='cluster_interpretation',
                                top_n_features=6, z_thresh=0.5,
                                modalities=None, stats_keywords=None,
                                random_state=42):
    """
    Produce interpretation report & figures for clustering results on physiomarker features.

    Inputs:
      - df_data: pandas DataFrame containing features and (optionally) other columns
      - feature_columns: list of column names in df_data to use for interpretation
      - cluster_labels: array-like of integer cluster labels for each row in df_data
      - out_dir: folder to save reports and figures
      - top_n_features: number of top positive/negative distinguishing features to list per cluster
      - z_thresh: z-score threshold for considering a modality/statistic elevated/reduced
      - modalities: iterable of strings to detect modalities in feature names; defaults to ['ecg','ppg','resp']
      - stats_keywords: keywords representing summary stats to search inside feature names
    Returns:
      - interpretations: dict keyed by cluster id containing interpretation info
    """
    np.random.seed(random_state)
    if modalities is None:
        modalities = ['ecg', 'ppg', 'resp']
    if stats_keywords is None:
        # common suffixes / keywords used in your features (adjust if needed)
        stats_keywords = ['mean', 'p25', 'p75', 'skew', 'entropy', 'median', 'std', 'var']

    os.makedirs(out_dir, exist_ok=True)

    # Subset features
    missing = [c for c in feature_columns if c not in df_data.columns]
    if missing:
        raise ValueError(f"Feature columns missing from dataframe: {missing}")
    X = df_data[feature_columns].copy().reset_index(drop=True)
    labels = np.asarray(cluster_labels).reshape(-1)
    if len(labels) != X.shape[0]:
        raise ValueError("cluster_labels length mismatch with number of rows in df_data[feature_columns].")

    clusters = np.unique(labels)
    n_clusters = len(clusters)
    n_samples = X.shape[0]

    # Global stats
    global_mean = X.mean(axis=0)
    global_std = X.std(axis=0).replace(0, 1e-8)  # avoid division by zero

    # Per-cluster summaries
    cluster_feature_means = pd.DataFrame(index=feature_columns, columns=clusters, dtype=float)
    cluster_counts = {}
    cluster_feature_skew = pd.DataFrame(index=feature_columns, columns=clusters, dtype=float)

    for c in clusters:
        idx = np.where(labels == c)[0]
        cluster_counts[int(c)] = len(idx)
        Xc = X.iloc[idx]
        cluster_feature_means[c] = Xc.mean(axis=0)
        # fallback skew using scipy.stats.skew (handle constant columns)
        try:
            cluster_feature_skew[c] = Xc.apply(lambda col: float(skew(col.dropna())) if col.dropna().size > 2 else 0.0)
        except Exception:
            cluster_feature_skew[c] = 0.0

    # Z-scores of cluster means relative to global distribution
    cluster_feature_z = (cluster_feature_means.subtract(global_mean, axis=0)).divide(global_std, axis=0)

    # Map features to modalities and stats by substring matching
    feat_to_mod = {}
    feat_to_stat = {}
    for feat in feature_columns:
        ln = feat.lower()
        matched_mods = [m.upper() for m in modalities if m in ln]
        feat_to_mod[feat] = matched_mods[0] if matched_mods else 'OTHER'
        matched_stats = [k for k in stats_keywords if k in ln]
        feat_to_stat[feat] = matched_stats[0] if matched_stats else 'other'

    # Compute modality-stat aggregated z-scores per cluster
    modality_stat_z = {c: defaultdict(list) for c in clusters}
    for c in clusters:
        for feat in feature_columns:
            mod = feat_to_mod[feat]
            stat = feat_to_stat[feat]
            modality_stat_z[c][(mod, stat)].append(cluster_feature_z.loc[feat, c])

    modality_stat_meanz = {}
    for c in clusters:
        modality_stat_meanz[c] = {k: float(np.mean(v)) if len(v) > 0 else 0.0 for k, v in modality_stat_z[c].items()}

    # Heuristic phrase building maps
    stat_phrase_map = {
        'mean': ('elevated mean amplitude', 'reduced mean amplitude'),
        'p75': ('higher upper-percentiles', 'lower upper-percentiles'),
        'p25': ('higher lower-percentiles', 'lower lower-percentiles'),
        'skew': ('asymmetric waveform distribution', 'opposite asymmetry'),
        'entropy': ('high signal irregularity', 'low signal irregularity'),
        'median': ('elevated median', 'reduced median'),
        'std': ('high variability', 'low variability'),
        'var': ('high variability', 'low variability'),
        'other': ('distinctive pattern', 'reduced distinctive pattern')
    }

    interpretations = {}

    # Find per-cluster representative indices (closest to cluster mean)
    cluster_centroids = cluster_feature_means.transpose().values  # clusters x features
    rep_indices = {}
    for i, c in enumerate(clusters):
        idx = np.where(labels == c)[0]
        if len(idx) == 0:
            rep_indices[int(c)] = []
            continue
        # compute euclidean distance to centroid in original feature space (means)
        # normalize by feature std for fairness
        centroid = cluster_feature_means[c].values
        Xc = X.iloc[idx].values
        dists = np.linalg.norm((Xc - centroid) / (global_std.values + 1e-8), axis=1)
        rep_local = np.argsort(dists)[:min(5, len(dists))]
        rep_indices[int(c)] = list(idx[rep_local])

    # Top discriminating features per cluster
    for c in clusters:
        z_series = cluster_feature_z[c].sort_values(ascending=False)
        top_pos = z_series.head(top_n_features)
        top_neg = z_series.tail(top_n_features)
        # Build modality-stat importance ordering
        ms_map = modality_stat_meanz[c]
        # Sort modality-stat by descending mean z
        ms_sorted = sorted(ms_map.items(), key=lambda kv: kv[1], reverse=True)

        # Compose phenotype name heuristically: pick top 2 (mod,stat) with mean z>z_thresh
        name_parts = []
        for (mod, stat), mz in ms_sorted[:4]:
            if abs(mz) >= z_thresh:
                if mz > 0:
                    phrase = stat_phrase_map.get(stat, stat_phrase_map['other'])[0]
                    name_parts.append(f"{mod}: {phrase}")
                else:
                    phrase = stat_phrase_map.get(stat, stat_phrase_map['other'])[1]
                    name_parts.append(f"{mod}: {phrase}")
            if len(name_parts) >= 2:
                break
        if len(name_parts) == 0:
            # fallback: choose most extreme feature-driven description
            fp = top_pos.index.tolist()[:2] + top_neg.index.tolist()[:1]
            name_parts = [f"{feat} {'↑' if cluster_feature_z.loc[feat,c]>0 else '↓'}" for feat in fp]

        phenotype_name = " & ".join(name_parts)
        # shorten overly long names
        if len(phenotype_name) > 100:
            phenotype_name = phenotype_name[:97] + "..."

        # Build textual summary
        summary_lines = []
        summary_lines.append(f"Cluster {int(c)} (n={cluster_counts[int(c)]}; {100*cluster_counts[int(c)]/n_samples:.1f}%):")
        summary_lines.append(f"  Phenotype name: {phenotype_name}")
        summary_lines.append("  Top positive distinguishing features (z > 0):")
        for feat, z in top_pos.items():
            summary_lines.append(f"    {feat}: z={z:.2f} (mod={feat_to_mod[feat]}, stat={feat_to_stat[feat]})")
        summary_lines.append("  Top negative distinguishing features (z < 0):")
        for feat, z in top_neg[::-1].items():  # show most negative first
            summary_lines.append(f"    {feat}: z={z:.2f} (mod={feat_to_mod[feat]}, stat={feat_to_stat[feat]})")
        # modality-stat table
        summary_lines.append("  Modality-stat mean z-scores (examples):")
        # show top modality-stat entries
        shown = 0
        for (mod, stat), mz in ms_sorted:
            summary_lines.append(f"    {mod}-{stat}: mean_z={mz:.2f}")
            shown += 1
            if shown >= 8:
                break
        summary_lines.append(f"  Representative sample indices (closest to centroid): {rep_indices[int(c)]}")

        interpretations[int(c)] = {
            'cluster': int(c),
            'count': int(cluster_counts[int(c)]),
            'percent': float(100*cluster_counts[int(c)]/n_samples),
            'phenotype_name': phenotype_name,
            'top_positive_features': top_pos.to_dict(),
            'top_negative_features': top_neg.to_dict(),
            'modality_stat_meanz': modality_stat_meanz[c],
            'representative_indices': rep_indices[int(c)],
            'text_summary': "\n".join(summary_lines)
        }

    # Save full tables
    cluster_feature_means.to_csv(os.path.join(out_dir, 'cluster_feature_means.csv'))
    cluster_feature_z.to_csv(os.path.join(out_dir, 'cluster_feature_z.csv'))

    # Save JSON of interpretations
    with open(os.path.join(out_dir, 'cluster_interpretations.json'), 'w') as f:
        json.dump(interpretations, f, indent=2)

    # Save plain text report
    with open(os.path.join(out_dir, 'cluster_report.txt'), 'w') as ftxt:
        title = f"Cluster Interpretation Report ({n_clusters} clusters, {n_samples} samples)\n\n"
        ftxt.write(title)
        for c in sorted(interpretations.keys()):
            ftxt.write(interpretations[c]['text_summary'] + "\n\n")

    # Plots: Heatmap of cluster-feature z-scores (trimmed for readability)
    plt.figure(figsize=(max(8, 0.15*len(feature_columns)), max(4, n_clusters*1.2)))
    sns.heatmap(cluster_feature_z.transpose(), cmap='vlag', center=0.0, cbar_kws={'label': 'z-score'},
                xticklabels=True, yticklabels=[f'Cluster {int(c)}' for c in clusters])
    plt.title('Cluster means (z-score normalized per feature)')
    plt.xlabel('Features')
    plt.ylabel('Clusters')
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, 'cluster_feature_z_heatmap.png'), dpi=200)
    plt.close()

    # Plot per-cluster bar of modality-stat mean z for top modalities
    for c in clusters:
        ms = modality_stat_meanz[c]
        if not ms:
            continue
        keys, vals = zip(*sorted(ms.items(), key=lambda kv: kv[1], reverse=True))
        labels_plot = [f"{k[0]}-{k[1]}" for k in keys[:12]]
        vals_plot = [float(v) for v in vals[:12]]
        plt.figure(figsize=(10, 4))
        sns.barplot(x=vals_plot, y=labels_plot, palette='coolwarm')
        plt.axvline(0, color='k', linewidth=0.5)
        plt.title(f'Cluster {int(c)}: modality-stat mean z (top)')
        plt.xlabel('mean z-score')
        plt.tight_layout()
        plt.savefig(os.path.join(out_dir, f'cluster_{int(c)}_modstat_bar.png'), dpi=200)
        plt.close()

    # Boxplots for top global distinguishing features (union of top features across clusters)
    union_features = set()
    for c in clusters:
        union_features.update(list(interpretations[int(c)]['top_positive_features'].keys()))
        union_features.update(list(interpretations[int(c)]['top_negative_features'].keys()))
    union_features = [f for f in feature_columns if f in union_features]
    if union_features:
        n_col = min(6, len(union_features))
        plt.figure(figsize=(max(8, 2*n_col), 4*int(np.ceil(len(union_features)/n_col))))
        for i, feat in enumerate(union_features):
            plt.subplot(int(np.ceil(len(union_features)/n_col)), n_col, i+1)
            sns.boxplot(x=labels, y=X[feat], palette='Set2')
            plt.title(feat)
            plt.xlabel('Cluster')
            plt.tight_layout()
        plt.suptitle('Distribution of Top Distinguishing Features by Cluster', y=1.02)
        plt.savefig(os.path.join(out_dir, 'top_features_boxplots.png'), dpi=200, bbox_inches='tight')
        plt.close()

    # Print summary to console
    print(f"Saved interpretation files to '{out_dir}'.")
    for c in sorted(interpretations.keys()):
        print(interpretations[c]['text_summary'].splitlines()[0])  # single-line summary

    return interpretations

